---
import type { LeaderboardData } from "@/types/leaderboard";

import leaderboardRaw from "@/data/leaderboard.json";

const leaderboard = leaderboardRaw as LeaderboardData;
---

<header class="border-b border-muted/20">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <div class="flex items-center gap-x-3">
      <a href="/synthbench/" class="flex items-center gap-2">
        <svg class="h-7 w-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 3v18h18" />
          <path d="M7 16l4-8 4 4 4-10" />
        </svg>
        <span class="text-xl font-bold tracking-tight">SynthBench</span>
      </a>
      <span class="text-xs text-muted hidden sm:inline">v{leaderboard.synthbench_version}</span>
    </div>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-x-6 text-sm">
      <a href="#leaderboard" class="text-muted hover:text-text dark:hover:text-text-dark transition-colors">Leaderboard</a>
      <a href="#charts" class="text-muted hover:text-text dark:hover:text-text-dark transition-colors">Charts</a>
      <a href="#about" class="text-muted hover:text-text dark:hover:text-text-dark transition-colors">About</a>
      <a
        href="https://github.com/DataViking-Tech/synthbench"
        class="inline-flex items-center gap-1.5 text-muted hover:text-text dark:hover:text-text-dark transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        GitHub
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="md:hidden -m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-muted"
      id="mobile-menu-btn"
      aria-label="Open menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div class="hidden md:hidden" id="mobile-menu">
    <div class="space-y-1 px-6 pb-4">
      <a href="#leaderboard" class="block py-2 text-sm text-muted hover:text-text dark:hover:text-text-dark">Leaderboard</a>
      <a href="#charts" class="block py-2 text-sm text-muted hover:text-text dark:hover:text-text-dark">Charts</a>
      <a href="#about" class="block py-2 text-sm text-muted hover:text-text dark:hover:text-text-dark">About</a>
      <a
        href="https://github.com/DataViking-Tech/synthbench"
        class="block py-2 text-sm text-muted hover:text-text dark:hover:text-text-dark"
        target="_blank"
        rel="noopener noreferrer"
      >GitHub</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
    // Close menu when a link is clicked
    for (const link of menu.querySelectorAll("a")) {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
      });
    }
  }
</script>
