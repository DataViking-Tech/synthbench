---
import Chart from "@/components/shared/Chart.astro";
import type { LeaderboardData } from "@/types/leaderboard";

import leaderboardRaw from "@/data/leaderboard.json";

const leaderboard = leaderboardRaw as LeaderboardData;

const convergence = leaderboard.convergence ?? [];

// Map raw provider strings to clean display names. Only providers that map to
// the target display names below are kept on the chart.
const providerDisplay: Record<string, string> = {
  "ensemble/3-model-blend": "SynthPanel Ensemble (3-model)",
  "openrouter/anthropic/claude-haiku-4-5": "Claude Haiku 4.5",
  "raw-anthropic/claude-haiku-4-5-20251001": "Claude Haiku 4.5",
  "openrouter/openai/gpt-4o-mini": "GPT-4o-mini",
  "openrouter/google/gemini-2.5-flash-lite": "Gemini Flash Lite",
  "raw-gemini/gemini-2.5-flash-lite": "Gemini Flash Lite",
};

const targetDisplayOrder = [
  "SynthPanel Ensemble (3-model)",
  "Claude Haiku 4.5",
  "Gemini Flash Lite",
  "GPT-4o-mini",
];

const modelColors: Record<string, string> = {
  "SynthPanel Ensemble (3-model)": "var(--color-provider-synthpanel)",
  "Claude Haiku 4.5": "#6366f1",
  "Gemini Flash Lite": "#0891b2",
  "GPT-4o-mini": "#d97706",
};

// Group by display name, keeping the best (highest SPS) point per rep_count.
const modelGroups = new Map<string, Map<number, number>>();
for (const pt of convergence) {
  const display = providerDisplay[pt.model];
  if (!display) continue;
  const bucket = modelGroups.get(display) ?? new Map<number, number>();
  const prev = bucket.get(pt.rep_count);
  if (prev === undefined || pt.sps > prev) {
    bucket.set(pt.rep_count, pt.sps);
  }
  modelGroups.set(display, bucket);
}

const presentModels = targetDisplayOrder.filter((name) => modelGroups.has(name));

const chartOption = {
  tooltip: {
    trigger: "axis",
    formatter: (params: { seriesName: string; value: number[]; marker: string }[]) => {
      const repCount = params[0]?.value[0];
      const lines = params.map(
        (p) => `${p.marker} ${p.seriesName}: SPS ${(p.value[1] as number).toFixed(3)}`,
      );
      return `<div style="font-size:13px"><strong>${repCount} replicates</strong><br/>${lines.join("<br/>")}</div>`;
    },
  },
  legend: { data: presentModels, top: 10 },
  grid: { left: 60, right: 40, top: 60, bottom: 40, containLabel: true },
  xAxis: {
    type: "value",
    name: "Replicate Count",
    nameLocation: "middle",
    nameGap: 30,
    min: 0,
  },
  yAxis: {
    type: "value",
    name: "SPS",
    nameLocation: "middle",
    nameGap: 45,
    min: 0,
    max: 1,
    axisLabel: { formatter: (v: number) => v.toFixed(1) },
  },
  series: presentModels.map((model) => {
    const bucket = modelGroups.get(model) ?? new Map<number, number>();
    const points = [...bucket.entries()]
      .map(([rep, sps]) => ({ rep_count: rep, sps }))
      .sort((a, b) => a.rep_count - b.rep_count);
    return {
      name: model,
      type: "line",
      data: points.map((p) => [p.rep_count, p.sps]),
      smooth: true,
      symbol: "circle",
      symbolSize: 8,
      lineStyle: { color: modelColors[model] ?? "#6366f1", width: 2 },
      itemStyle: { color: modelColors[model] ?? "#6366f1" },
      emphasis: {
        focus: "series",
        lineStyle: { width: 4 },
      },
    };
  }),
  toolbox: {
    feature: { saveAsImage: { title: "Save as PNG" } },
    right: 10,
    top: 10,
  },
};

const hasData = presentModels.length > 0;
---

<section class="w-full max-w-4xl mx-auto py-8">
  <h2 class="text-2xl font-bold text-center mb-2">SPS Convergence</h2>
  <p class="text-center text-sm text-muted mb-6">
    How SPS stabilizes as replicate count increases. Showing the ensemble and the three blended single models.
  </p>
  {hasData ? (
    <Chart option={chartOption} height="400px" />
  ) : (
    <div class="text-center text-muted py-12 border border-muted/20 rounded-lg">
      Convergence data not yet available. Run evaluations with multiple replicate counts to populate.
    </div>
  )}
</section>
