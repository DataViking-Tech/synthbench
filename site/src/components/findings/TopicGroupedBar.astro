---
import Chart from "@/components/shared/Chart.astro";
import type { LeaderboardData, LeaderboardEntry } from "@/types/leaderboard";

import leaderboardRaw from "@/data/leaderboard.json";

const leaderboard = leaderboardRaw as LeaderboardData;

// Full topic taxonomy — show every slot even when a model didn't score on it.
const ALL_TOPICS = [
  "Politics & Governance",
  "International Relations & Security",
  "Economy & Work",
  "Technology & Digital Life",
  "Media & Information",
  "Health & Science",
  "Social Values & Religion",
  "Identity & Demographics",
  "Trust & Wellbeing",
  "General Attitudes",
];

// Best per (display name + dataset), excluding baselines. Entries that are
// temperature/template variants lose to the plain config (same key, lower or
// equal SPS) because we keep only the highest-SPS entry per key.
const bestByKey = new Map<string, LeaderboardEntry>();
for (const entry of leaderboard.entries) {
  if (entry.is_baseline) continue;
  if (!entry.topic_scores) continue;
  const key = `${entry.model}::${entry.dataset}`;
  const existing = bestByKey.get(key);
  if (!existing || entry.sps > existing.sps) {
    bestByKey.set(key, entry);
  }
}

// Roll up to one row per model — keep the dataset where that model scored highest.
const bestByModel = new Map<string, LeaderboardEntry>();
for (const entry of bestByKey.values()) {
  const existing = bestByModel.get(entry.model);
  if (!existing || entry.sps > existing.sps) {
    bestByModel.set(entry.model, entry);
  }
}

const models = [...bestByModel.values()].sort((a, b) => b.sps - a.sps);

const modelColors: Record<string, string> = {
  "SynthPanel Ensemble (3-model)": "var(--color-provider-synthpanel)",
  "SynthPanel (Haiku 4.5)": "#7c3aed",
  "SynthPanel (Gemini Flash Lite)": "#0891b2",
  "SynthPanel (GPT-4o-mini)": "#d97706",
  "SynthPanel (Sonnet 4)": "#9333ea",
  "Claude Haiku 4.5": "#6366f1",
  "Gemini Flash Lite (direct)": "#22d3ee",
  "GPT-4o-mini": "#f59e0b",
  "Claude Sonnet 4": "#a78bfa",
  "GPT-4o": "#fbbf24",
  "Gemini 2.5 Flash": "#0ea5e9",
  "Llama 3.3 70B": "#94a3b8",
  "Claude Haiku 4.5 (direct)": "#818cf8",
};

const chartOption = {
  tooltip: {
    trigger: "axis",
    axisPointer: { type: "shadow" },
    formatter: (params: { seriesName: string; value: number; marker: string; name?: string }[]) => {
      const topic = params[0]?.name ?? "";
      const active = params.filter((p) => typeof p.value === "number");
      if (active.length === 0)
        return `<div style="font-size:13px"><strong>${topic}</strong><br/>no data</div>`;
      const lines = active.map(
        (p) => `${p.marker} ${p.seriesName}: ${(p.value as number).toFixed(3)}`,
      );
      return `<div style="font-size:13px"><strong>${topic}</strong><br/>${lines.join("<br/>")}</div>`;
    },
  },
  legend: {
    data: models.map((m) => m.model),
    top: 10,
    type: "scroll",
  },
  grid: { left: 60, right: 30, top: 60, bottom: 50, containLabel: true },
  xAxis: {
    type: "category",
    data: ALL_TOPICS,
    axisLabel: {
      rotate: 30,
      overflow: "truncate",
      width: 100,
    },
  },
  yAxis: {
    type: "value",
    name: "SPS",
    nameLocation: "middle",
    nameGap: 45,
    min: 0,
    max: 1,
    axisLabel: { formatter: (v: number) => v.toFixed(1) },
  },
  series: models.map((model) => ({
    name: model.model,
    type: "bar",
    data: ALL_TOPICS.map((t) => {
      const score = model.topic_scores?.[t as keyof typeof model.topic_scores];
      return typeof score === "number" ? score : null;
    }),
    itemStyle: { color: modelColors[model.model] ?? "#6366f1" },
    barMaxWidth: 28,
    emphasis: {
      focus: "series",
      itemStyle: { shadowBlur: 10, shadowColor: "rgba(0,0,0,0.3)" },
    },
  })),
  toolbox: {
    feature: { saveAsImage: { title: "Save as PNG" } },
    right: 10,
    top: 10,
  },
};

const hasTopics = models.length > 0;
---

<section class="w-full max-w-4xl mx-auto py-8">
  <h2 class="text-2xl font-bold text-center mb-2">SPS by Topic</h2>
  <p class="text-center text-sm text-muted mb-6">
    Best-per-model performance across the ten topic categories. Baselines and temperature variants hidden; scroll the legend to toggle models.
  </p>
  {hasTopics ? (
    <Chart option={chartOption} height="450px" />
  ) : (
    <div class="text-center text-muted py-12 border border-muted/20 rounded-lg">
      Topic score data not yet available.
    </div>
  )}
</section>
