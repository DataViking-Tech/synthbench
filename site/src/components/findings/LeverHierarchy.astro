---
import Chart from "@/components/shared/Chart.astro";
import type { LeaderboardData } from "@/types/leaderboard";

import leaderboardRaw from "@/data/leaderboard.json";

const leaderboard = leaderboardRaw as LeaderboardData;
const levers = [...(leaderboard.findings.lever_hierarchy ?? [])];

// Sort by effect_max descending, then effect_min descending for ties
levers.sort((a, b) => b.effect_max - a.effect_max || b.effect_min - a.effect_min);

const costColors: Record<string, string> = {
  zero: "#059669",
  low: "#3b82f6",
  moderate: "#d97706",
  high: "#dc2626",
};

const costLabels: Record<string, string> = {
  zero: "Zero cost",
  low: "Low cost",
  moderate: "Moderate cost",
  high: "High cost",
};

const leverNames = levers.map((l) => l.name);

const chartOption = {
  tooltip: {
    trigger: "item" as const,
  },
  grid: { left: 20, right: 100, top: 10, bottom: 30, containLabel: true },
  xAxis: {
    type: "value" as const,
    name: "Effect Size (SPS points)",
    nameLocation: "middle" as const,
    nameGap: 25,
    min: 0,
    max: 8,
  },
  yAxis: {
    type: "category" as const,
    data: leverNames,
    inverse: true,
    axisLabel: { width: 200, overflow: "truncate" as const },
  },
  series: [
    {
      name: "Minimum",
      type: "bar" as const,
      stack: "range",
      data: levers.map((l) => l.effect_min),
      itemStyle: { color: "transparent", borderColor: "transparent" },
      emphasis: { itemStyle: { color: "transparent" } },
      silent: true,
      barWidth: 22,
    },
    {
      name: "Effect Range",
      type: "bar" as const,
      stack: "range",
      data: levers.map((l) => ({
        value: l.effect_max - l.effect_min,
        name: costLabels[l.cost] ?? l.cost,
        itemStyle: {
          color: costColors[l.cost] ?? "#6366f1",
          borderRadius: [0, 4, 4, 0],
        },
      })),
      barWidth: 22,
      label: {
        show: true,
        position: "right" as const,
        formatter: "{b}",
        fontSize: 11,
        color: "#888",
      },
    },
  ],
  toolbox: {
    feature: { saveAsImage: { title: "Save as PNG" } },
    right: 10,
    top: 0,
  },
};

const hasData = levers.length > 0;
---

<section class="w-full max-w-4xl mx-auto py-8">
  <h2 class="text-2xl font-bold text-center mb-2">What Matters Most</h2>
  <p class="text-center text-sm text-muted mb-6">
    Effect size of each optimization lever, sorted by maximum impact.
    Ensemble blending delivers +5-7 SPS points at zero additional cost.
  </p>
  {hasData ? (
    <Chart option={chartOption} height="300px" />
  ) : (
    <div class="text-center text-muted py-12 border border-muted/20 rounded-lg">
      Lever hierarchy data not yet available.
    </div>
  )}
</section>
