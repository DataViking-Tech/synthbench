---
import leaderboardRaw from "@/data/leaderboard.json";

interface Baseline {
  name: string;
  description: string;
  tests: string;
  spsRange: string;
  position: string;
  extended?: {
    sections: { heading: string; body: string }[];
    statusNote?: string;
    seeAlso?: { href: string; label: string };
  };
}

// Pull the subgroup ceiling distribution out of leaderboard.json so the
// methodology page shows the same numbers that the leaderboard uses when
// scoring P_sub. Fall back to null if the publish step hasn't emitted the
// subgroup block yet — the extra section is skipped silently in that case.
type CeilingDict = { mean?: number };
type SubgroupDistribution = {
  min: number;
  p25: number;
  median: number;
  p75: number;
  max: number;
};
type WorstSubgroup = {
  wave: string;
  attribute: string;
  group: string;
  ceiling: CeilingDict;
};
type OpinionsQASubgroupBlock = {
  distribution?: SubgroupDistribution;
  subgroup_ceiling_for_psub?: number;
  worst_5_subgroups?: WorstSubgroup[];
  quality_breakdown?: Record<string, number>;
  n_subgroups?: number;
};
type OpinionsQACeilingBlock = {
  overall?: CeilingDict;
  per_subgroup?: OpinionsQASubgroupBlock;
};
type BaselinesBlock = {
  ceiling?: { opinionsqa?: OpinionsQACeilingBlock };
};
type RawLeaderboard = { baselines?: BaselinesBlock };

const rawBaselines = (leaderboardRaw as RawLeaderboard).baselines ?? {};
const oqaCeiling: OpinionsQACeilingBlock = rawBaselines.ceiling?.opinionsqa ?? {};
const oqaAggregateMean: number | null = oqaCeiling.overall?.mean ?? null;
const oqaSubgroup: OpinionsQASubgroupBlock | null = oqaCeiling.per_subgroup ?? null;
const oqaSubgroupDist: SubgroupDistribution | null = oqaSubgroup?.distribution ?? null;
const oqaSubgroupMedian: number | null =
  oqaSubgroup?.subgroup_ceiling_for_psub ?? oqaSubgroupDist?.median ?? null;
const oqaWorst: WorstSubgroup[] = Array.isArray(oqaSubgroup?.worst_5_subgroups)
  ? oqaSubgroup.worst_5_subgroups.slice(0, 5)
  : [];
const oqaQualityBreakdown: Record<string, number> | null = oqaSubgroup?.quality_breakdown ?? null;
const oqaNSubgroups: number | null = oqaSubgroup?.n_subgroups ?? null;

function fmt(x: number | null | undefined, digits = 4): string {
  if (x == null || Number.isNaN(x)) return "—";
  return x.toFixed(digits);
}

const baselines: Baseline[] = [
  {
    name: "Random Baseline",
    description:
      "Uniform random distribution over all non-refusal options. For a question with k options, each gets P = 1/k.",
    tests: "The absolute floor. Any provider scoring at or below this is adding negative value.",
    spsRange: "~0.31",
    position: "floor",
  },
  {
    name: "Majority-Class",
    description:
      "Always picks the most popular human answer. Assigns P = 1.0 to the mode, 0.0 to everything else.",
    tests:
      "Whether a model does better than just echoing the most common response. Scores well on consensus questions, poorly on divisive ones.",
    spsRange: "~0.45",
    position: "low",
  },
  {
    name: "Population-Average",
    description:
      "Uses the overall population distribution (ignoring demographics) for every group. The same answer regardless of who is being simulated.",
    tests:
      "Isolates the value of demographic conditioning. The gap between this baseline and a conditioned provider is the conditioning premium.",
    spsRange: "~0.52",
    position: "mid",
  },
  {
    name: "Unconditioned LLM",
    description:
      'Raw model output with no persona or demographic conditioning. This is the "just prompt ChatGPT" approach many researchers currently use.',
    tests:
      "The competitive baseline. Every dedicated synthetic respondent product must beat this to justify its existence.",
    spsRange: "~0.58",
    position: "high",
  },
  {
    name: "Human Ceiling",
    description:
      "Agreement between independent halves of the human survey panel, measured via multinomial-bootstrap split-half reliability. The theoretical maximum score a model can achieve.",
    tests:
      "A provider scoring above this is overfitting or exploiting artifacts. Sets the upper bound for meaningful evaluation.",
    spsRange: "~0.99",
    position: "ceiling",
    extended: {
      sections: [
        {
          heading: "What it is",
          body: "Split-half reliability via multinomial bootstrap. Given observed counts c = [c_1, ..., c_k] with total n per question × subpop, we treat p̂ = c/n as the multinomial MLE and draw two independent half-samples of size ⌊n/2⌋ from Multinomial(n/2, p̂). We compute JSD between the two empirical distributions, repeat B times, and report Ceiling = 1 − mean(JSD). Published values use B=200 to keep build times tractable; the pure function supports B=1000 for standalone analysis. CIs at B=200 are ~1.5× wider than at B=1000; point estimates differ by <0.0005.",
        },
        {
          heading: "Why it matters",
          body: "It is the theoretical maximum for any evaluation built on this human data. Humans disagree with each other; no model can be more consistent with the survey than the survey is with itself. Per-subpopulation ceilings genuinely differ — Spearman-Brown says reliability scales with √n — so small subpops have materially lower ceilings than large ones.",
        },
        {
          heading: "Per-dataset protocol",
          body: "OpinionsQA: computed within-wave (never cross-wave — that measures drift, not reliability), aggregated weighted by n_questions per wave. SubPOP: per-subpop (22 subpopulations) + weighted aggregate. GlobalOpinionQA: per-country + regional aggregates, weighted by actual (country, question) coverage to avoid over-weighting US data.",
        },
        {
          heading: "Two granularities: aggregate vs subgroup",
          body: "P_dist is measured at wave granularity (~4.5k respondents/wave), so it compares against the wave-aggregate ceiling (~0.9995). P_sub is measured at (wave × attribute × group) granularity — typical n is 50-500, not 4,500 — so the aggregate ceiling materially overstates achievable headroom. OpinionsQA now emits a per-subgroup ceiling distribution and uses the median as the reference for P_sub; the wave-aggregate is kept for P_dist. A model at P_sub = 0.88 is not sitting 0.12 below a true ceiling of 0.9995 — its real headroom is the gap to the subgroup median, which is meaningfully smaller and shrinks further on low-n groups where the ceiling itself drops to ~0.95.",
        },
        {
          heading: "Measured values (v0.1)",
          body: "OpinionsQA: 0.9995 (raw counts from 15 Pew ATP waves, n≈56k/wave). SubPOP: 0.9954 (22 subpops, inferred n=500 per subpop, quality flag 'medium'). GlobalOpinionQA: 0.9972 (per-country, inferred n=1000, quality flag 'medium'). All values are reproducible with bootstrap seed 42. The high ceilings reflect large within-wave sample sizes; the realistic gap between models and humans is most visible on small, contentious subpops.",
        },
        {
          heading: "Sample-size quality flags (Cochran 1977)",
          body: "High: raw subpop n ≥ 400 — use directly. Medium: 200 ≤ n < 400 — report with CI caveat. Low: n < 200 — report with warning; do not use as a gating threshold. SubPOP and GlobalOpinionQA ceilings are flagged 'medium' because sample sizes are inferred from published probabilities, not shipped as raw counts.",
        },
        {
          heading: "Survey-weight caveat",
          body: "Ceiling is computed from raw category counts. Pew applies survey weights; ignoring them could shift the ceiling by 1-3% on demographically skewed subgroups. The raw-count approach is conservative — a weighted ceiling would be slightly tighter, meaning our published ceilings are a mild upper-bound on achievable reliability.",
        },
        {
          heading: "Citations",
          body: "Methodology: Santurkar et al. 2023 (arxiv:2303.17548); Durmus et al. 2023 (arxiv:2306.16388); Geng & Liu 2024 (SubPOP); Pew Research Center Methodology. Statistical foundations: Spearman (1910) & Brown (1910) — Spearman-Brown prophecy; Efron (1979) — bootstrap; Lin (1991) — Jensen-Shannon divergence; Cochran (1977) — Sampling Techniques, for the n=400 rule-of-thumb.",
        },
      ],
    },
  },
  {
    name: "Temporal Drift Floor",
    description:
      "A baseline-adjacent metric separate from Human Ceiling: JSD between the same-wording questions across different Pew ATP waves. Pew repeats ~15-20% of items across waves for trend tracking.",
    tests:
      "Quantifies how much real-world opinions shift year-over-year on repeated items. Useful framing for P_refuse and longitudinal claims — drift is a property of reality, not of a model.",
    spsRange: "N/A",
    position: "ceiling",
    extended: {
      sections: [
        {
          heading: "What it is",
          body: "For every OpinionsQA question stem that appears in two or more waves, we compute JSD between its human distributions across waves. We report mean JSD overall, broken down by year-gap (1, 2, 3, 5 years), with bootstrap 95% CI over question pairs.",
        },
        {
          heading: "Why it is separate from the Human Ceiling",
          body: "Split-half reliability must be within-wave: cross-wave JSD conflates sampling noise with real opinion shift. Temporal Drift Floor captures only the latter. A model that perfectly predicts 2022 opinions using 2017 training data would still score imperfectly against 2017 humans — the drift floor tells you how much of that gap is unavoidable.",
        },
        {
          heading: "Status",
          body: "Computed for OpinionsQA only (requires same-wording repeated questions, which Pew ATP uniquely ships). Not applicable to SubPOP or GlobalOpinionQA snapshots. Values emitted to leaderboard.json under baselines.temporal_drift.",
        },
      ],
      seeAlso: {
        href: "/findings/#temporal-drift-floor",
        label: "See drift-by-year-gap visualization on the Findings page",
      },
    },
  },
];
---

<section class="w-full max-w-4xl mx-auto py-12" id="baselines">
  <h2
    class="text-2xl font-bold tracking-tight text-text dark:text-text-dark mb-2"
  >
    Baselines: What to Compare Against
  </h2>
  <p class="text-muted mb-8 max-w-2xl">
    A model that scores 0.70 SPS sounds good — until you realize the
    majority-class baseline scores 0.45. Baselines give meaning to raw scores by
    anchoring the scale.
  </p>

  <!-- Values table — primary reference -->
  <div
    class="rounded-lg border border-muted/20 bg-surface mb-6 dark:bg-surface-dark overflow-x-auto"
  >
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-muted/20 text-left">
          <th class="px-4 py-2 font-semibold">Baseline</th>
          <th class="px-4 py-2 font-semibold text-right">SPS</th>
          <th class="px-4 py-2 font-semibold text-muted">Role</th>
        </tr>
      </thead>
      <tbody>
        {
          baselines.map((b) => (
            <tr class="border-b border-muted/10 last:border-b-0">
              <td class="px-4 py-2 font-medium">{b.name}</td>
              <td class="px-4 py-2 text-right font-mono text-primary dark:text-primary-light">
                {b.spsRange}
              </td>
              <td class="px-4 py-2 text-muted capitalize">{b.position}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <!-- Visual scale (supplementary) -->
  <div
    class="rounded-lg border border-muted/20 bg-surface p-6 pb-16 mb-8 dark:bg-surface-dark overflow-x-auto"
  >
    <div class="min-w-[560px]">
      <div class="relative h-8 bg-muted/10 rounded-full">
        {/* Gradient fill from 0 to 1 */}
        <div
          class="absolute inset-y-0 left-0 rounded-full"
          style="width: 100%; background: linear-gradient(to right, oklch(0.65 0.05 30), oklch(0.55 0.18 264));"
        >
        </div>
        {/* Axis endpoints */}
        <div
          class="absolute top-full mt-1 text-[10px] font-medium text-muted"
          style="left: 0%;"
        >
          0.0
        </div>
        <div
          class="absolute top-full mt-1 text-[10px] font-medium text-muted -translate-x-full"
          style="left: 100%;"
        >
          1.0
        </div>
        {/* Markers — value above, name below, alternating vertical offset to avoid overlap */}
        {
          baselines
            .filter((b) => !Number.isNaN(parseFloat(b.spsRange.replace("~", ""))))
            .map((b, i) => {
            const value = parseFloat(b.spsRange.replace("~", ""));
            const pct = value * 100;
            const stagger = i % 2 === 0 ? "mt-5" : "mt-10";
            return (
              <div class="absolute top-0 bottom-0" style={`left: ${pct}%;`}>
                {/* Tick line through the bar */}
                <div class="absolute inset-y-0 left-0 w-0.5 bg-text/70 dark:bg-text-dark/70" />
                {/* Value label above the bar */}
                <span class="absolute bottom-full mb-1 -translate-x-1/2 text-[11px] font-bold font-mono text-text dark:text-text-dark whitespace-nowrap">
                  {b.spsRange}
                </span>
                {/* Name label below with staggered offset */}
                <span
                  class:list={["absolute top-full -translate-x-1/2 text-[10px] font-medium text-muted whitespace-nowrap", stagger]}
                >
                  {b.name.replace(" Baseline", "")}
                </span>
              </div>
            );
          })
        }
      </div>
      <div class="mt-16 text-center text-xs text-muted">
        Meaningful evaluation range: Unconditioned LLM (~0.58) to Human Ceiling
        (~0.99)
      </div>
    </div>
  </div>

  <!-- Normalized position (Range %) -->
  <div
    class="rounded-lg border border-muted/20 bg-surface p-5 mb-8 dark:bg-surface-dark"
    id="normalized-position"
  >
    <h3 class="text-base font-semibold text-text dark:text-text-dark mb-2">
      Normalized position ("Range %")
    </h3>
    <p class="text-sm text-muted mb-3">
      Raw SPS values for strong models compress into a narrow band (~0.82-0.85)
      that is visually hard to separate on a 0-1 bar. The leaderboard also
      reports a <em>normalized position</em> — where a row sits inside the
      meaningful evaluation range bounded below by the raw-LLM baseline and
      above by the Human Ceiling.
    </p>
    <pre
      class="rounded-md border border-muted/20 bg-muted/5 p-3 text-xs font-mono overflow-x-auto dark:bg-muted/10"
    >Range % = (SPS − P_unconditioned) / (P_ceiling − P_unconditioned)</pre>
    <p class="mt-3 text-sm text-text/80 dark:text-text-dark/80">
      <span class="font-medium">P_unconditioned</span> is the SPS of the raw-LLM
      baseline for the same underlying model on the same dataset (the "just
      prompt the model" reference). Raw-LLM rows therefore resolve to 0% —
      they <em>are</em> the reference. Product rows (e.g. conditioned SynthPanel
      variants) show their lift above the corresponding raw model.
    </p>
    <p class="mt-2 text-sm text-text/80 dark:text-text-dark/80">
      <span class="font-medium">P_ceiling</span> is the dataset's aggregate Human
      Ceiling (see below). Rows without a resolvable raw-LLM baseline (statistical
      baselines, multi-model ensembles) display "—" for Range % and should be
      compared via raw SPS instead.
    </p>
    <p class="mt-2 text-xs italic text-muted">
      Raw SPS remains the primary column for academic comparability. Range % is
      a supplementary display that amplifies product lift — a 0.01 SPS gain on
      a narrow range becomes a double-digit percentage of headroom closed.
    </p>
  </div>

  {
    oqaSubgroupDist && (
      <div
        class="rounded-lg border border-muted/20 bg-surface p-5 mb-6 dark:bg-surface-dark"
        id="opinionsqa-subgroup-ceiling"
      >
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
          <h3 class="text-base font-semibold text-text dark:text-text-dark">
            OpinionsQA: subgroup ceiling distribution
          </h3>
          <span class="text-sm font-mono text-primary dark:text-primary-light">
            median {fmt(oqaSubgroupMedian)}
          </span>
        </div>
        <p class="text-sm text-muted mb-4">
          Per-(wave, attribute, group) ceilings across {oqaNSubgroups ?? "—"}{" "}
          subgroups from 15 Pew ATP waves. The wave-aggregate ceiling (
          {fmt(oqaAggregateMean)}, used for P_dist) is a different quantity
          and does not bound P_sub.
        </p>

        {/* Min / p25 / median / p75 / max callout */}
        <div class="grid grid-cols-5 gap-2 text-center mb-4">
          {(["min", "p25", "median", "p75", "max"] as const).map((k) => (
            <div class="rounded border border-muted/20 py-2">
              <div class="text-[10px] uppercase tracking-wide text-muted">
                {k}
              </div>
              <div class="text-sm font-mono font-semibold text-text dark:text-text-dark">
                {fmt(oqaSubgroupDist[k])}
              </div>
            </div>
          ))}
        </div>

        {/* Range visualization with median marker */}
        {(() => {
          const min = oqaSubgroupDist.min;
          const max = oqaSubgroupDist.max;
          const p25 = oqaSubgroupDist.p25;
          const p75 = oqaSubgroupDist.p75;
          const median = oqaSubgroupDist.median;
          const span = Math.max(max - min, 1e-9);
          const pct = (v: number) => ((v - min) / span) * 100;
          return (
            <div class="relative h-6 bg-muted/10 rounded-full mb-6">
              {/* IQR band */}
              <div
                class="absolute inset-y-0 rounded-full bg-primary/20"
                style={`left: ${pct(p25)}%; right: ${100 - pct(p75)}%;`}
              />
              {/* Whiskers (min..p25, p75..max) via endpoint ticks */}
              <div
                class="absolute inset-y-1 w-0.5 bg-muted/60"
                style={`left: ${pct(min)}%;`}
              />
              <div
                class="absolute inset-y-1 w-0.5 bg-muted/60"
                style={`left: ${pct(max)}%;`}
              />
              {/* Median tick */}
              <div
                class="absolute -inset-y-1 w-0.5 bg-primary dark:bg-primary-light"
                style={`left: ${pct(median)}%;`}
              />
              <div
                class="absolute -bottom-5 text-[10px] font-mono text-muted -translate-x-1/2"
                style={`left: ${pct(min)}%;`}
              >
                {fmt(min, 3)}
              </div>
              <div
                class="absolute -bottom-5 text-[10px] font-mono text-muted -translate-x-1/2"
                style={`left: ${pct(max)}%;`}
              >
                {fmt(max, 3)}
              </div>
            </div>
          );
        })()}

        {oqaWorst.length > 0 && (
          <div class="mt-2">
            <h4 class="text-xs font-semibold uppercase tracking-wide text-muted mb-1">
              Lowest-ceiling subgroups
            </h4>
            <ul class="space-y-1">
              {oqaWorst.map((w) => (
                <li class="flex justify-between text-sm">
                  <span class="truncate">
                    <span class="text-muted">{w.wave}</span>
                    <span class="mx-1">·</span>
                    <span class="font-medium">{w.attribute}</span>
                    <span class="mx-1">·</span>
                    <span>{w.group}</span>
                  </span>
                  <span class="font-mono text-text/80 dark:text-text-dark/80 pl-2">
                    {fmt(w.ceiling?.mean)}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {oqaQualityBreakdown && (
          <p class="mt-3 text-xs text-muted">
            Quality flags (Cochran 1977):{" "}
            <span class="font-mono">
              {oqaQualityBreakdown.high ?? 0} high
            </span>
            {" · "}
            <span class="font-mono">
              {oqaQualityBreakdown.medium ?? 0} medium
            </span>
            {" · "}
            <span class="font-mono">
              {oqaQualityBreakdown.low ?? 0} low
            </span>
            {" — low-n subgroups are retained but flagged so low reliability is not conflated with poor model fit."}
          </p>
        )}

        <p class="mt-3 text-xs italic text-muted border-l-2 border-muted/40 pl-3">
          Used by the leaderboard when scoring P_sub; compare P_dist against the
          wave-aggregate ceiling instead.
        </p>
      </div>
    )
  }

  <!-- Baseline cards -->
  <div class="space-y-4">
    {
      baselines.map((b) => (
        <div class="rounded-lg border border-muted/20 bg-surface p-5 dark:bg-surface-dark">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
            <h3 class="text-base font-semibold text-text dark:text-text-dark">
              {b.name}
            </h3>
            <span class="text-sm font-mono text-primary dark:text-primary-light">
              SPS {b.spsRange}
            </span>
          </div>
          <p class="text-sm text-muted mb-2">{b.description}</p>
          <p class="text-sm text-text/80 dark:text-text-dark/80">
            <span class="font-medium">What it tests:</span> {b.tests}
          </p>
          {b.extended && (
            <div class="mt-4 pt-4 border-t border-muted/20 space-y-3">
              {b.extended.sections.map((s) => (
                <div>
                  <h4 class="text-sm font-semibold text-text dark:text-text-dark mb-1">
                    {s.heading}
                  </h4>
                  <p class="text-sm text-muted">{s.body}</p>
                </div>
              ))}
              {b.extended.statusNote && (
                <p class="text-xs italic text-muted border-l-2 border-muted/40 pl-3">
                  {b.extended.statusNote}
                </p>
              )}
              {b.extended.seeAlso && (
                <p class="text-sm">
                  <span class="font-medium">See also:</span>{" "}
                  <a
                    href={b.extended.seeAlso.href}
                    class="text-primary dark:text-primary-light underline underline-offset-2 hover:no-underline"
                  >
                    {b.extended.seeAlso.label}
                  </a>
                </p>
              )}
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>
