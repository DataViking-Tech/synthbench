---
const phases = [
  {
    number: 1,
    title: "US Opinion Parity",
    status: "current",
    datasets: "OpinionsQA, SubPOP",
    metrics: "P_dist, P_rank, P_cond, P_sub, P_refuse",
    description:
      "Establish the core benchmark with US survey data. Validate metrics against human baselines and publish initial leaderboard.",
  },
  {
    number: 2,
    title: "Global Cultural Parity",
    status: "planned",
    datasets: "GlobalOpinionQA expansion",
    metrics: "+ cross-cultural P_dist",
    description:
      "Extend evaluation to 138 countries. Test whether models capture cultural differences in opinion beyond US demographics.",
  },
  {
    number: 3,
    title: "Open-Ended Qualitative",
    status: "planned",
    datasets: "Custom open-ended question sets",
    metrics: "+ P_theme (LLM-as-judge)",
    description:
      "Move beyond multiple choice. Evaluate free-text responses for thematic accuracy using automated judge models.",
  },
  {
    number: 4,
    title: "Temporal Stability",
    status: "planned",
    datasets: "Longitudinal tracking panels",
    metrics: "+ temporal drift metrics",
    description:
      "Track how model accuracy changes over time. Measure whether models keep pace as public opinion shifts.",
  },
];
---

<section class="w-full max-w-4xl mx-auto py-12" id="roadmap">
  <h2
    class="text-2xl font-bold tracking-tight text-text dark:text-text-dark mb-2"
  >
    Roadmap
  </h2>
  <p class="text-muted mb-8 max-w-2xl">
    SynthBench expands in phases, each adding new ground-truth datasets and
    metric dimensions.
  </p>

  <div class="relative">
    {/* Connecting line */}
    <div
      class="absolute left-6 top-0 bottom-0 w-0.5 bg-muted/20 hidden sm:block"
    >
    </div>

    <div class="space-y-6">
      {
        phases.map((p) => (
          <div class="relative flex gap-4 sm:gap-6">
            {/* Phase indicator */}
            <div
              class:list={[
                "relative z-10 flex size-12 shrink-0 items-center justify-center rounded-full text-sm font-bold",
                p.status === "current"
                  ? "bg-primary text-white ring-4 ring-primary/20 dark:bg-primary-light dark:ring-primary-light/20"
                  : "bg-muted/15 text-muted border border-muted/30",
              ]}
            >
              {p.number}
            </div>

            {/* Content */}
            <div
              class:list={[
                "flex-1 rounded-lg border p-5",
                p.status === "current"
                  ? "border-primary/30 bg-primary/5 dark:border-primary-light/20 dark:bg-primary-light/5"
                  : "border-muted/20 bg-surface dark:bg-surface-dark",
              ]}
            >
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                <h3 class="text-base font-semibold text-text dark:text-text-dark">
                  Phase {p.number}: {p.title}
                </h3>
                {p.status === "current" && (
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-primary/15 text-primary dark:bg-primary-light/15 dark:text-primary-light">
                    Current
                  </span>
                )}
              </div>

              <p class="text-sm text-muted mb-3">{p.description}</p>

              <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs">
                <div>
                  <span class="text-muted">Datasets:</span>{" "}
                  <span class="font-medium text-text dark:text-text-dark">
                    {p.datasets}
                  </span>
                </div>
                <div>
                  <span class="text-muted">Metrics:</span>{" "}
                  <span class="font-medium text-text dark:text-text-dark">
                    {p.metrics}
                  </span>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
