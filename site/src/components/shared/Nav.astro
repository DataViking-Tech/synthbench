---
import leaderboardRaw from "@/data/leaderboard.json";
import type { LeaderboardData } from "@/types/leaderboard";

const leaderboard = leaderboardRaw as LeaderboardData;

const currentPath = Astro.url.pathname;
const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const baseNoTrail = base.replace(/\/$/, "");

const navLinks = [
  { href: base, label: "Home" },
  { href: `${base}leaderboard/`, label: "Leaderboard" },
  { href: `${base}explore/`, label: "Explore" },
  { href: `${base}findings/`, label: "Findings" },
  { href: `${base}methodology/`, label: "Methodology" },
  { href: `${base}submit/`, label: "Submit" },
];

function isActive(href: string): boolean {
  if (href === base) {
    return currentPath === base || currentPath === baseNoTrail;
  }
  return currentPath.startsWith(href);
}
---

<header class="bg-surface dark:bg-surface-dark">
  <nav aria-label="Global" class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8">
    <div class="flex lg:flex-1">
      <a href={base} class="-m-1.5 flex items-center gap-2 p-1.5">
        <svg class="h-8 w-auto text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 3v18h18" />
          <path d="M7 16l4-8 4 4 4-10" />
        </svg>
        <span class="text-xl font-bold tracking-tight text-text dark:text-text-dark">SynthBench</span>
        <span class="hidden text-xs text-muted sm:inline" data-vrt-mask>v{leaderboard.synthbench_version}</span>
      </a>
    </div>
    <div class="flex lg:hidden">
      <button
        type="button"
        class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-muted"
        id="mobile-menu-open"
        aria-label="Open main menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-12">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-sm/6 font-semibold",
            isActive(link.href)
              ? "text-primary dark:text-primary-light"
              : "text-text dark:text-text-dark hover:text-primary dark:hover:text-primary-light",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end">
      <a
        href="https://github.com/DataViking-Tech/synthbench"
        class="inline-flex items-center gap-1.5 text-sm/6 font-semibold text-text dark:text-text-dark"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" fill-rule="evenodd" />
        </svg>
        GitHub<span class="sr-only"> (opens in a new tab)</span> <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div class="hidden lg:hidden" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Main menu">
    <div class="fixed inset-0 z-50 bg-surface/80 dark:bg-surface-dark/80" id="mobile-menu-backdrop"></div>
    <div class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-surface p-6 sm:max-w-sm sm:ring-1 sm:ring-muted/10 dark:bg-surface-dark dark:sm:ring-muted/10" id="mobile-menu-panel">
      <div class="flex items-center justify-between">
        <a href={base} class="-m-1.5 flex items-center gap-2 p-1.5">
          <svg class="h-8 w-auto text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 3v18h18" />
            <path d="M7 16l4-8 4 4 4-10" />
          </svg>
          <span class="text-xl font-bold tracking-tight text-text dark:text-text-dark">SynthBench</span>
        </a>
        <button type="button" class="-m-2.5 rounded-md p-2.5 text-muted" id="mobile-menu-close" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
            <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
      <div class="mt-6 flow-root">
        <div class="-my-6 divide-y divide-muted/10">
          <div class="space-y-2 py-6">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold",
                  isActive(link.href)
                    ? "text-primary bg-primary/5 dark:text-primary-light"
                    : "text-text hover:bg-muted/10 dark:text-text-dark dark:hover:bg-muted/10",
                ]}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
          <div class="py-6">
            <a
              href="https://github.com/DataViking-Tech/synthbench"
              class="-mx-3 block rounded-lg px-3 py-2.5 text-base/7 font-semibold text-text hover:bg-muted/10 dark:text-text-dark dark:hover:bg-muted/10"
              target="_blank"
              rel="noopener noreferrer"
            >GitHub<span class="sr-only"> (opens in a new tab)</span></a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const openBtn = document.getElementById("mobile-menu-open");
  const closeBtn = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const panel = document.getElementById("mobile-menu-panel");

  const FOCUSABLE =
    'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';

  let lastFocused: HTMLElement | null = null;

  function getFocusables(): HTMLElement[] {
    if (!panel) return [];
    return Array.from(panel.querySelectorAll<HTMLElement>(FOCUSABLE)).filter(
      (el) => !el.hasAttribute("hidden") && el.offsetParent !== null,
    );
  }

  function onKeyDown(e: KeyboardEvent): void {
    if (e.key === "Escape") {
      e.preventDefault();
      closeMenu();
      return;
    }
    if (e.key !== "Tab") return;
    const nodes = getFocusables();
    if (nodes.length === 0) return;
    const first = nodes[0];
    const last = nodes[nodes.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (e.shiftKey) {
      if (active === first || !panel?.contains(active)) {
        e.preventDefault();
        last.focus();
      }
    } else if (active === last) {
      e.preventDefault();
      first.focus();
    }
  }

  function openMenu(): void {
    if (!menu) return;
    lastFocused = document.activeElement as HTMLElement | null;
    menu.classList.remove("hidden");
    openBtn?.setAttribute("aria-expanded", "true");
    document.addEventListener("keydown", onKeyDown);
    // Move focus into the dialog (first interactive element — close button).
    queueMicrotask(() => closeBtn?.focus());
  }

  function closeMenu(): void {
    if (!menu) return;
    menu.classList.add("hidden");
    openBtn?.setAttribute("aria-expanded", "false");
    document.removeEventListener("keydown", onKeyDown);
    // Restore focus to whatever opened the menu (usually the hamburger).
    (lastFocused ?? openBtn)?.focus();
  }

  openBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  backdrop?.addEventListener("click", closeMenu);

  // Close menu when a nav link is clicked
  for (const link of menu?.querySelectorAll("a") ?? []) {
    link.addEventListener("click", closeMenu);
  }
</script>
