---
const steps = [
  {
    title: "Subclass Provider",
    detail:
      "Create a new file in src/synthbench/providers/ and subclass Provider from providers/base.py. Implement async respond() and the name property.",
  },
  {
    title: "Wire distribution output (optional)",
    detail:
      "If your provider returns logprobs or native probabilities, override get_distribution() and set supports_distribution to True. Otherwise the base class samples respond() to build an empirical distribution.",
  },
  {
    title: "Register in the PROVIDERS dict",
    detail:
      "Add a name -> dotted path entry in src/synthbench/providers/__init__.py so the CLI can load it via --provider <your-name>.",
  },
  {
    title: "Test end-to-end",
    detail:
      "Run synthbench run --provider <your-name> --dataset opinionsqa against a small question slice, then submit the result JSON as usual.",
  },
];

const example = `from synthbench.providers.base import Provider, Response, PersonaSpec

class MyProvider(Provider):
    @property
    def name(self) -> str:
        return "my-provider"

    async def respond(
        self,
        question: str,
        options: list[str],
        *,
        persona: PersonaSpec | None = None,
    ) -> Response:
        # Call your API, pick an option from \`options\`
        choice = await call_my_api(question, options, persona)
        return Response(selected_option=choice)`;
---

<section class="w-full max-w-4xl mx-auto py-12" id="adapters">
  <h2
    class="text-2xl font-bold tracking-tight text-text dark:text-text-dark mb-2"
  >
    Adding a New Provider
  </h2>
  <p class="text-muted mb-8 max-w-2xl">
    Benchmarking a net-new provider or product? Write a thin adapter — the harness
    handles sampling, parsing, and metrics.
  </p>

  <ol class="space-y-4 mb-8">
    {
      steps.map((s, i) => (
        <li class="flex gap-3">
          <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-primary text-white text-xs font-bold dark:bg-primary-light">
            {i + 1}
          </span>
          <div>
            <h3 class="text-sm font-semibold text-text dark:text-text-dark">
              {s.title}
            </h3>
            <p class="text-sm text-muted mt-1">{s.detail}</p>
          </div>
        </li>
      ))
    }
  </ol>

  <div
    class="rounded-lg border border-muted/20 bg-surface dark:bg-surface-dark overflow-hidden"
  >
    <div
      class="px-4 py-2 text-xs font-mono text-muted border-b border-muted/20"
    >
      src/synthbench/providers/my_provider.py
    </div>
    <pre
      class="p-6 text-sm/6 font-mono text-text dark:text-text-dark overflow-x-auto"
    >{example}</pre>
  </div>

  <p class="text-sm text-muted mt-6">
    See{" "}
    <a
      href="https://github.com/DataViking-Tech/synthbench/blob/main/src/synthbench/providers/ollama.py"
      class="text-primary hover:underline dark:text-primary-light"
      target="_blank"
      rel="noopener noreferrer"
    >
      ollama.py
    </a>{" "}
    for a compact example (HTTP-backed, sampling-only), or{" "}
    <a
      href="https://github.com/DataViking-Tech/synthbench/blob/main/src/synthbench/providers/raw_openai.py"
      class="text-primary hover:underline dark:text-primary-light"
      target="_blank"
      rel="noopener noreferrer"
    >
      raw_openai.py
    </a>{" "}
    for a logprob-based adapter that overrides get_distribution().
  </p>
</section>
