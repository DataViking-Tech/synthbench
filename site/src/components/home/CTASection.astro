---
const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

const ctas = [
  {
    title: "Run your first benchmark",
    description:
      "Three commands to install the CLI, score your model against real survey data, and see where it lands on the leaderboard.",
    href: `${base}submit/#quick-start`,
    label: "See the quickstart",
    external: false,
  },
  {
    title: "Explore the methodology",
    description:
      "How we score models, what the Survey Parity Score measures, and why distribution fidelity matters for synthetic respondents.",
    href: `${base}methodology/`,
    label: "Read methodology",
    external: false,
  },
  {
    title: "Submit your model",
    description:
      "Run the full benchmark on your model and add your results to the public leaderboard. Open to any provider or framework.",
    href: `${base}submit/`,
    label: "Submit results",
    external: false,
  },
];
---

<section class="w-full max-w-5xl mx-auto py-12 px-4">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {ctas.map((cta) => (
      <div class="rounded-lg border border-muted/20 p-6 bg-surface dark:bg-surface-dark flex flex-col">
        <h3 class="text-lg font-semibold mb-2">{cta.title}</h3>
        <p class="text-sm text-muted leading-relaxed mb-4 flex-1">
          {cta.description}
        </p>
        <a
          href={cta.href}
          class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary-dark transition-colors"
          {...(cta.external
            ? { target: "_blank", rel: "noopener noreferrer" }
            : {})}
        >
          {cta.label}
          {cta.external && <span class="ml-1" aria-hidden="true">&nearr;</span>}
        </a>
      </div>
    ))}
  </div>
  <p class="mt-8 text-center text-sm text-muted">
    Using SynthPanel for synthetic surveys?{" "}
    <a
      href="https://github.com/DataViking-Tech/SynthPanel"
      class="text-primary dark:text-primary-light hover:underline"
      target="_blank"
      rel="noopener noreferrer"
    >
      Get SynthPanel on GitHub<span class="ml-0.5" aria-hidden="true">&nearr;</span>
    </a>
  </p>
</section>
