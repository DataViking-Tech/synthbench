---
import type { LeaderboardData, LeaderboardEntry } from "@/types/leaderboard";

import leaderboardRaw from "@/data/leaderboard.json";

const leaderboard = leaderboardRaw as LeaderboardData;

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

function formatNormalized(value: number | undefined): string {
  if (value == null || Number.isNaN(value)) return "—";
  return `${Math.round(value * 100)}%`;
}

function configHref(entry: LeaderboardEntry): string | null {
  return entry.config_id ? `${base}config/${entry.config_id}/` : null;
}

function rowAriaLabel(entry: LeaderboardEntry): string {
  const parts = [entry.model, entry.dataset, `SPS ${entry.sps.toFixed(3)}`];
  return `View configuration details for ${parts.join(", ")}`;
}

// Group entries by dataset, sort by SPS desc, take top 3 non-baseline
const topEntries: { dataset: string; entries: LeaderboardEntry[] }[] = [];

for (const ds of leaderboard.datasets) {
  const dsEntries = leaderboard.entries
    .filter((e) => e.dataset === ds && !e.is_baseline)
    .sort((a, b) => b.sps - a.sps)
    .slice(0, 3);
  topEntries.push({ dataset: ds, entries: dsEntries });
}
---

<section class="w-full max-w-5xl mx-auto py-12 px-4">
  <h2 id="summary-leaderboard-heading" class="text-2xl font-bold text-center mb-2">Leaderboard Summary</h2>
  <p class="text-center text-sm text-muted mb-8">
    Top 3 models per dataset by Survey Parity Score · activate a row (Enter) for config details
  </p>

  <div class="overflow-x-auto rounded-lg border border-muted/20" aria-labelledby="summary-leaderboard-heading">
    <table class="w-full text-sm" id="summary-leaderboard-table">
      <caption class="sr-only">Top 3 models per dataset by Survey Parity Score. Activate a row to open its configuration page.</caption>
      <thead>
        <tr class="bg-surface dark:bg-surface-dark border-b border-muted/20">
          <th class="px-4 py-3 text-left font-semibold" scope="col">#</th>
          <th class="px-4 py-3 text-left font-semibold" scope="col">Model</th>
          <th class="px-4 py-3 text-left font-semibold" scope="col">Dataset</th>
          <th class="px-4 py-3 text-right font-semibold" scope="col">SPS</th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" title="Position in the meaningful evaluation range: (SPS − raw-LLM baseline) / (Human Ceiling − raw-LLM baseline)">Range %</th>
          <th class="px-4 py-3 text-right font-semibold" scope="col">p_dist</th>
          <th class="px-4 py-3 text-right font-semibold" scope="col">p_rank</th>
        </tr>
      </thead>
      <tbody>
        {topEntries.map((group) =>
          group.entries.map((entry, i) => {
            const href = configHref(entry);
            const label = rowAriaLabel(entry);
            return (
            <tr
              class:list={[
                "summary-row border-b border-muted/10 transition-colors outline-none",
                href && "cursor-pointer hover:bg-primary/5 dark:hover:bg-primary/10 focus-visible:bg-primary/10",
                entry.is_ensemble && "bg-primary/5",
                i === 0 && "font-medium",
              ]}
              data-href={href ?? undefined}
              role={href ? "link" : undefined}
              tabindex={href ? 0 : undefined}
              aria-label={href ? label : undefined}
            >
              <td class="px-4 py-2.5 text-muted">{i + 1}</td>
              <td class="px-4 py-2.5">
                {href ? (
                  <a href={href} class="hover:underline focus-visible:underline" tabindex={-1}>{entry.model}</a>
                ) : (
                  <span>{entry.model}</span>
                )}
                {entry.is_ensemble && (
                  <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-primary/10 text-primary" title={entry.provider}>
                    ensemble
                  </span>
                )}
                {!entry.is_baseline && !entry.is_ensemble && entry.provider.startsWith("SynthPanel") && (
                  <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-provider-synthpanel/10 text-provider-synthpanel" title={entry.provider}>
                    conditioned
                  </span>
                )}
                {entry.temperature != null && (
                  <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-accent/15 text-accent font-mono" title={`temperature=${entry.temperature}`}>
                    t={entry.temperature}
                  </span>
                )}
                {entry.template && (
                  <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-accent/15 text-accent font-mono" title={`prompt template=${entry.template}`}>
                    tpl={entry.template}
                  </span>
                )}
              </td>
              <td class="px-4 py-2.5 text-muted">{entry.dataset}</td>
              <td class="px-4 py-2.5 text-right font-mono">
                {entry.sps.toFixed(3)}
              </td>
              <td class="px-4 py-2.5 text-right font-mono text-muted" title={entry.normalized_sps != null ? "(SPS − raw-LLM baseline) / (Human Ceiling − raw-LLM baseline)" : "No raw-LLM baseline available for this row"}>
                {formatNormalized(entry.normalized_sps)}
              </td>
              <td class="px-4 py-2.5 text-right font-mono">
                {entry.p_dist.toFixed(3)}
              </td>
              <td class="px-4 py-2.5 text-right font-mono">
                {entry.p_rank.toFixed(3)}
              </td>
            </tr>
            );
          }),
        )}
      </tbody>
    </table>
  </div>

  <p class="mt-4 text-center flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
    <a
      href={`${base}leaderboard/`}
      class="text-sm font-semibold text-primary dark:text-primary-light hover:underline"
    >
      View full leaderboard &rarr;
    </a>
    <a
      href={`${base}explore/`}
      class="text-sm font-semibold text-primary dark:text-primary-light hover:underline"
    >
      Explore all runs &rarr;
    </a>
  </p>
</section>

<script>
  function initSummaryLeaderboard() {
    const table = document.getElementById("summary-leaderboard-table");
    if (!table) return;
    const rows = table.querySelectorAll<HTMLTableRowElement>("tr.summary-row[data-href]");
    for (const row of rows) {
      const href = row.dataset.href;
      if (!href) continue;

      const navigate = () => {
        window.location.href = href;
      };

      row.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;
        if (target.closest("a")) return;
        if (window.getSelection()?.toString()) return;
        navigate();
      });

      row.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          const target = event.target as HTMLElement;
          if (target !== row) return;
          event.preventDefault();
          navigate();
        }
      });
    }
  }

  initSummaryLeaderboard();
</script>
