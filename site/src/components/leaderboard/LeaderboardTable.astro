---
import type { LeaderboardData, LeaderboardEntry } from "@/types/leaderboard";

import leaderboardRaw from "@/data/leaderboard.json";

const leaderboard = leaderboardRaw as LeaderboardData;
const entries = leaderboard.entries;

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

function formatNormalized(value: number | undefined): string {
  if (value == null || Number.isNaN(value)) return "—";
  return `${Math.round(value * 100)}%`;
}

function configHref(entry: LeaderboardEntry): string | null {
  return entry.config_id ? `${base}config/${entry.config_id}/` : null;
}

function rowAriaLabel(entry: LeaderboardEntry): string {
  const parts = [entry.model, entry.dataset, `SPS ${entry.sps.toFixed(3)}`];
  if (entry.temperature != null) parts.push(`t=${entry.temperature}`);
  if (entry.template) parts.push(`tpl=${entry.template}`);
  return `View configuration details for ${parts.join(", ")}`;
}

function fmtMetric(value: number | undefined): string {
  return value == null || Number.isNaN(value) ? "—" : value.toFixed(3);
}

// cost-metrics Slice 4 (sb-xij). Nullable → "—"; exact zero → "$0.00";
// positive but <$0.01 → "<$0.01"; otherwise two-decimal dollars.
function formatCost(value: number | null | undefined): string {
  if (value == null || Number.isNaN(value)) return "—";
  if (value === 0) return "$0.00";
  if (value > 0 && value < 0.01) return "<$0.01";
  return `$${value.toFixed(2)}`;
}

interface TopicRow {
  topic: string;
  sps: number;
  p_dist?: number;
  p_rank?: number;
  p_refuse?: number;
  n?: number;
}

function topicRows(entry: LeaderboardEntry): TopicRow[] {
  if (entry.topic_metrics) {
    return Object.entries(entry.topic_metrics)
      .map(([topic, m]) => ({ topic, ...m }))
      .sort((a, b) => b.sps - a.sps);
  }
  if (entry.topic_scores) {
    return Object.entries(entry.topic_scores)
      .map(([topic, sps]) => ({ topic, sps: sps as number }))
      .sort((a, b) => b.sps - a.sps);
  }
  return [];
}

// Default view hides under-replicated variant configs. A "variant" is any
// (model, temperature, template) triple that overrides temperature or
// template — stability matters more for these because they're easy to
// over-fit. Hide when either:
//   * run_count < 3      (fewer than 3 replicates for this exact row)
//   * dataset_coverage_count < 2  (config only tested on one dataset)
// Falls back to in-JS grouping when publish.py hasn't emitted the fields.
const configCoverageFallback = new Map<string, Set<string>>();
for (const entry of entries) {
  const key = `${entry.model}::t=${entry.temperature ?? ""}::tpl=${entry.template ?? ""}`;
  const set = configCoverageFallback.get(key) ?? new Set<string>();
  set.add(entry.dataset);
  configCoverageFallback.set(key, set);
}

function hiddenInDefaultView(entry: LeaderboardEntry): boolean {
  const isVariant = entry.temperature != null || entry.template != null;
  if (!isVariant) return false;

  const runCount = entry.run_count;
  if (runCount != null && runCount < 3) return true;

  let coverage = entry.dataset_coverage_count;
  if (coverage == null) {
    const key = `${entry.model}::t=${entry.temperature ?? ""}::tpl=${entry.template ?? ""}`;
    coverage = configCoverageFallback.get(key)?.size ?? 0;
  }
  return coverage < 2;
}

// Only surface the badge-explanation banner when at least one row actually
// carries a verification badge. Otherwise it reads as noise.
const hasVerificationBadges = entries.some(
  (e) => e.verification_badge === "verified" || e.verification_badge === "flagged",
);
---

<section class="w-full max-w-5xl mx-auto py-8" id="leaderboard" aria-labelledby="leaderboard-heading">
  <h2 id="leaderboard-heading" class="text-2xl font-bold text-center mb-2">Leaderboard</h2>
  <p class="text-center text-sm text-muted mb-6">
    Select a column header to sort. Activate a row (Enter) to open its configuration, or use the chevron button to expand details inline.
  </p>

  <!-- Visually hidden status region announces sort changes. -->
  <p id="leaderboard-sort-status" class="sr-only" role="status" aria-live="polite"></p>

  {hasVerificationBadges && (
    <aside
      class="mb-6 rounded-lg border border-muted/20 bg-surface/60 dark:bg-surface-dark/60 px-4 py-3 text-sm text-muted"
      aria-label="Verification badge key"
    >
      <p>
        <span class="inline-block text-xs px-1.5 py-0.5 rounded bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 mr-1">✓ verified</span>
        rows matched our hidden 20% private-holdout check.
        <span class="inline-block text-xs px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-700 dark:text-amber-400 mx-1">⚠ flagged</span>
        rows diverged beyond the public/private SPS threshold and are under review — not disqualified. Hover any badge for row-specific detail, or read the <a href={`${base}methodology/#private-holdout`} class="underline hover:text-primary focus-visible:text-primary">private-holdout methodology</a>.
      </p>
    </aside>
  )}

  <!-- Desktop table -->
  <div class="hidden md:block overflow-x-auto rounded-lg border border-muted/20">
    <table class="w-full text-sm" id="leaderboard-table">
      <caption class="sr-only">Synthetic survey respondent quality leaderboard. Each row is a model result; activate the row to open its config page, or expand via the chevron button for inline detail.</caption>
      <thead>
        <tr class="bg-surface dark:bg-surface-dark border-b border-muted/20">
          <th class="px-2 py-3 w-8" scope="col"><span class="sr-only">Expand row</span></th>
          <th class="px-4 py-3 text-left font-semibold" scope="col" aria-sort="none"><button type="button" class="flex items-center gap-1 font-semibold hover:text-primary" data-sort="rank">#</button></th>
          <th class="px-4 py-3 text-left font-semibold" scope="col" aria-sort="none"><button type="button" class="flex items-center gap-1 font-semibold hover:text-primary" data-sort="model" data-sort-type="string">Model <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-left font-semibold" scope="col" aria-sort="none"><button type="button" class="flex items-center gap-1 font-semibold hover:text-primary" data-sort="dataset" data-sort-type="string">Dataset <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-left font-semibold" scope="col" aria-sort="none"><button type="button" class="flex items-center gap-1 font-semibold hover:text-primary" data-sort="framework" data-sort-type="string">Framework <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none"><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="sps">SPS <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none" title="Position in the meaningful evaluation range: (SPS − raw-LLM baseline) / (Human Ceiling − raw-LLM baseline). Shown only when a raw-LLM baseline is available for the underlying model."><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="normalized_sps">Range % <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none"><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="p_dist">p_dist <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none"><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="p_rank">p_rank <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none"><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="p_refuse">p_refuse <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none"><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="n">N <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none" title="Cost in US dollars to run 100 questions at this config's token usage and the pricing snapshot at publish time. Rows without token usage show —."><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="cost_per_100q">$/100Q <span class="sort-indicator" aria-hidden="true"></span></button></th>
          <th class="px-4 py-3 text-right font-semibold" scope="col" aria-sort="none"><button type="button" class="ml-auto flex items-center gap-1 font-semibold hover:text-primary" data-sort="ci">95% CI <span class="sort-indicator" aria-hidden="true"></span></button></th>
        </tr>
      </thead>
      <tbody>
        {entries.map((entry, i) => {
          const detailId = `lb-detail-${i}`;
          const href = configHref(entry);
          const label = rowAriaLabel(entry);
          return (
          <>
          <tr
            class:list={[
              "leaderboard-row border-b border-muted/10 transition-colors outline-none",
              href && "cursor-pointer hover:bg-primary/5 dark:hover:bg-primary/10 focus-visible:bg-primary/10",
              entry.is_baseline && "bg-baseline/5",
              entry.is_ensemble && "bg-primary/5",
            ]}
            data-entry={JSON.stringify(entry)}
            data-dataset={entry.dataset}
            data-variant={hiddenInDefaultView(entry) ? "variant" : "best"}
            data-href={href ?? undefined}
            role={href ? "link" : undefined}
            tabindex={href ? 0 : undefined}
            aria-label={href ? label : undefined}
          >
            <td class="px-2 py-3 text-center">
              <button
                type="button"
                class="expand-chevron inline-flex items-center justify-center w-6 h-6 rounded text-muted hover:text-primary hover:bg-primary/10"
                aria-label={`Toggle configuration details for ${entry.model} on ${entry.dataset}`}
                aria-expanded="false"
                aria-controls={detailId}
              >
                <span class="chevron-icon inline-block transition-transform" aria-hidden="true">▶</span>
              </button>
            </td>
            <td class="px-4 py-3 text-muted">{entry.rank}</td>
            <td class="px-4 py-3 font-medium">
              {href ? (
                <a href={href} class="hover:underline focus-visible:underline" tabindex={-1}>{entry.model}</a>
              ) : (
                <span>{entry.model}</span>
              )}
              {entry.is_ensemble && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-primary/10 text-primary" title={entry.provider}>ensemble</span>}
              {entry.is_baseline && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-muted/20 text-muted" title={entry.provider}>baseline</span>}
              {!entry.is_baseline && entry.provider.startsWith("SynthPanel") && !entry.is_ensemble && (
                <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-provider-synthpanel/10 text-provider-synthpanel" title={entry.provider}>conditioned</span>
              )}
              {entry.verification_badge === "verified" && (
                <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-emerald-500/10 text-emerald-700 dark:text-emerald-400" title={
                  entry.sps_public != null && entry.sps_private != null
                    ? `Public SPS ${entry.sps_public.toFixed(3)} vs private SPS ${entry.sps_private.toFixed(3)} — delta within threshold`
                    : "Private holdout scores agree — within divergence threshold"
                }>✓ verified</span>
              )}
              {entry.verification_badge === "flagged" && (
                <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-700 dark:text-amber-400" title={
                  entry.sps_public != null && entry.sps_private != null
                    ? `Public SPS ${entry.sps_public.toFixed(3)} vs private SPS ${entry.sps_private.toFixed(3)} — delta exceeds threshold, under review`
                    : "Public/private SPS diverge beyond threshold — under review"
                }>⚠ flagged</span>
              )}
              {entry.temperature != null && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-accent/15 text-accent font-mono"><span class="sr-only">temperature </span>t={entry.temperature}</span>}
              {entry.template && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-accent/15 text-accent font-mono"><span class="sr-only">prompt template </span>tpl={entry.template}</span>}
              <span class="block text-xs text-muted">{entry.provider}</span>
            </td>
            <td class="px-4 py-3">{entry.dataset}</td>
            <td class="px-4 py-3 text-xs text-muted">{entry.framework}</td>
            <td class="px-4 py-3 text-right font-mono">{entry.sps.toFixed(3)}</td>
            <td class="px-4 py-3 text-right font-mono text-muted" title={entry.normalized_sps != null ? "(SPS − raw-LLM baseline) / (Human Ceiling − raw-LLM baseline)" : "No raw-LLM baseline available for this row"}>{formatNormalized(entry.normalized_sps)}</td>
            <td class="px-4 py-3 text-right font-mono">{entry.p_dist.toFixed(3)}</td>
            <td class="px-4 py-3 text-right font-mono">{entry.p_rank.toFixed(3)}</td>
            <td class="px-4 py-3 text-right font-mono">{entry.p_refuse.toFixed(3)}</td>
            <td class="px-4 py-3 text-right font-mono">{entry.n}</td>
            <td class="px-4 py-3 text-right font-mono cost-cell" data-cost-per-100q={entry.cost_per_100q ?? ""}>{formatCost(entry.cost_per_100q)}</td>
            <td class="px-4 py-3 text-right font-mono text-xs">
              [{entry.ci_lower.toFixed(3)}, {entry.ci_upper.toFixed(3)}]
            </td>
          </tr>
          <tr id={detailId} class="detail-row hidden border-b border-muted/10" data-dataset={entry.dataset} data-variant={hiddenInDefaultView(entry) ? "variant" : "best"}>
            <td colspan="13" class="px-4 py-4 bg-surface/50 dark:bg-surface-dark/50">
              <div class="space-y-4 text-sm">
                {(() => {
                  const rows = topicRows(entry);
                  if (rows.length === 0) return null;
                  const hasFull = rows.some((r) => r.p_dist != null || r.p_rank != null || r.p_refuse != null);
                  return (
                    <div>
                      <h3 class="font-semibold mb-2">Topic Scores</h3>
                      <div class="overflow-x-auto rounded border border-muted/20">
                        <table class="w-full text-xs">
                          <thead>
                            <tr class="bg-surface dark:bg-surface-dark border-b border-muted/20 text-muted">
                              <th class="px-3 py-1.5 text-left font-medium" scope="col">Topic</th>
                              <th class="px-3 py-1.5 text-right font-medium" scope="col" title="SynthBench Parity Score — equal-weighted composite">SPS</th>
                              {hasFull && (
                                <>
                                  <th class="px-3 py-1.5 text-right font-medium" scope="col" title="Distributional parity: 1 − mean(JSD)">p_dist</th>
                                  <th class="px-3 py-1.5 text-right font-medium" scope="col" title="Rank-order parity: (1 + mean(τ)) / 2">p_rank</th>
                                  <th class="px-3 py-1.5 text-right font-medium" scope="col" title="Refusal calibration: 1 − mean(|R_model − R_human|)">p_refuse</th>
                                  <th class="px-3 py-1.5 text-right font-medium" scope="col" title="Questions per topic">N</th>
                                </>
                              )}
                            </tr>
                          </thead>
                          <tbody>
                            {rows.map((r) => (
                              <tr class="border-b border-muted/10 last:border-b-0">
                                <td class="px-3 py-1.5">{r.topic}</td>
                                <td class="px-3 py-1.5 text-right font-mono">{r.sps.toFixed(3)}</td>
                                {hasFull && (
                                  <>
                                    <td class="px-3 py-1.5 text-right font-mono text-muted">{fmtMetric(r.p_dist)}</td>
                                    <td class="px-3 py-1.5 text-right font-mono text-muted">{fmtMetric(r.p_rank)}</td>
                                    <td class="px-3 py-1.5 text-right font-mono text-muted">{fmtMetric(r.p_refuse)}</td>
                                    <td class="px-3 py-1.5 text-right font-mono text-muted">{r.n ?? "—"}</td>
                                  </>
                                )}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  );
                })()}
                {entry.replicates && entry.replicates.length > 0 && (
                  <div>
                    <h3 class="font-semibold mb-2">Replicates</h3>
                    <div class="space-y-1">
                      {entry.replicates.map((rep) => (
                        <div class="flex justify-between text-xs">
                          <span class="text-muted">Rep {rep.rep}</span>
                          <span class="font-mono">SPS {rep.sps.toFixed(3)} / p_dist {rep.p_dist.toFixed(3)} / p_rank {rep.p_rank.toFixed(3)}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
                {!entry.topic_scores && !entry.topic_metrics && !entry.replicates && (
                  <div class="text-muted">No additional detail data available.</div>
                )}
              </div>
            </td>
          </tr>
          </>
          );
        })}
      </tbody>
    </table>
  </div>

  <!-- Mobile card layout -->
  <ul class="md:hidden space-y-3 list-none p-0">
    {entries.map((entry) => {
      const href = configHref(entry);
      const label = rowAriaLabel(entry);
      const cardClasses = [
        "leaderboard-card block rounded-lg border border-muted/20 p-4 transition-colors",
        href && "cursor-pointer hover:border-primary/30",
        entry.is_baseline && "bg-baseline/5",
        entry.is_ensemble && "bg-primary/5",
      ];
      const Inner = (
        <>
        <div class="flex items-baseline justify-between mb-2">
          <div>
            <span class="font-medium">{entry.model}</span>
            {entry.is_ensemble && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-primary/10 text-primary">ensemble</span>}
            {entry.is_baseline && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-muted/20 text-muted">baseline</span>}
            {!entry.is_baseline && entry.provider.startsWith("SynthPanel") && !entry.is_ensemble && (
              <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-provider-synthpanel/10 text-provider-synthpanel">conditioned</span>
            )}
            {entry.temperature != null && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-accent/15 text-accent font-mono"><span class="sr-only">temperature </span>t={entry.temperature}</span>}
            {entry.template && <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-accent/15 text-accent font-mono"><span class="sr-only">prompt template </span>tpl={entry.template}</span>}
          </div>
          <div class="text-right">
            <span class="text-lg font-mono font-bold">{entry.sps.toFixed(3)}</span>
            {entry.normalized_sps != null && (
              <span class="ml-1 text-xs font-mono text-muted" title="(SPS − raw-LLM baseline) / (Human Ceiling − raw-LLM baseline)">{formatNormalized(entry.normalized_sps)}</span>
            )}
          </div>
        </div>
        <div class="text-xs text-muted mb-2">{entry.provider} · {entry.dataset} · {entry.framework}</div>
        <div class="grid grid-cols-2 gap-2 text-xs">
          <div><span class="text-muted">p_dist</span> <span class="font-mono">{entry.p_dist.toFixed(3)}</span></div>
          <div><span class="text-muted">p_rank</span> <span class="font-mono">{entry.p_rank.toFixed(3)}</span></div>
          <div><span class="text-muted">p_refuse</span> <span class="font-mono">{entry.p_refuse.toFixed(3)}</span></div>
          <div title="Cost in US dollars to run 100 questions"><span class="text-muted">$/100Q</span> <span class="font-mono cost-cell" data-cost-per-100q={entry.cost_per_100q ?? ""}>{formatCost(entry.cost_per_100q)}</span></div>
        </div>
        </>
      );
      return href ? (
        <li>
          <a
            href={href}
            class:list={cardClasses}
            data-dataset={entry.dataset}
            data-variant={hiddenInDefaultView(entry) ? "variant" : "best"}
            aria-label={label}
          >
            {Inner}
          </a>
        </li>
      ) : (
        <li
          class:list={cardClasses}
          data-dataset={entry.dataset}
          data-variant={hiddenInDefaultView(entry) ? "variant" : "best"}
        >
          {Inner}
        </li>
      );
    })}
  </ul>
</section>

<script>
  function announce(message: string): void {
    const status = document.getElementById("leaderboard-sort-status");
    if (status) status.textContent = message;
  }

  function initLeaderboard() {
    const table = document.getElementById("leaderboard-table");
    if (!table) return;

    const tbody = table.querySelector("tbody");
    if (!tbody) return;

    // Chevron: toggle next detail row without navigating
    const chevrons = tbody.querySelectorAll<HTMLButtonElement>(".expand-chevron");
    for (const btn of chevrons) {
      btn.addEventListener("click", (event) => {
        event.stopPropagation();
        const controls = btn.getAttribute("aria-controls");
        if (!controls) return;
        const detail = document.getElementById(controls);
        if (!detail?.classList.contains("detail-row")) return;
        const expanded = btn.getAttribute("aria-expanded") === "true";
        const next = !expanded;
        btn.setAttribute("aria-expanded", String(next));
        detail.classList.toggle("hidden", !next);
        const icon = btn.querySelector(".chevron-icon") as HTMLElement | null;
        if (icon) icon.style.transform = next ? "rotate(90deg)" : "";
      });
    }

    // Row: navigate to config page on click / Enter / Space
    const rows = tbody.querySelectorAll<HTMLTableRowElement>("tr.leaderboard-row[data-href]");
    for (const row of rows) {
      const href = row.dataset.href;
      if (!href) continue;

      const navigate = () => {
        window.location.href = href;
      };

      row.addEventListener("click", (event) => {
        // Ignore clicks on interactive descendants (chevron button, anchor tags)
        const target = event.target as HTMLElement;
        if (target.closest(".expand-chevron")) return;
        if (target.closest("a")) return;
        if (window.getSelection()?.toString()) return;
        navigate();
      });

      row.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          const target = event.target as HTMLElement;
          if (target !== row) return;
          event.preventDefault();
          navigate();
        }
      });
    }

    // Sort — button-in-th pattern with aria-sort on th.
    const sortButtons = table.querySelectorAll<HTMLButtonElement>(
      "thead button[data-sort]",
    );
    const allTh = table.querySelectorAll<HTMLTableCellElement>(
      "thead th[aria-sort]",
    );
    let currentSort = "";
    let ascending = true;

    for (const btn of sortButtons) {
      btn.addEventListener("click", () => {
        const sortKey = btn.dataset.sort ?? "";
        const sortType = btn.dataset.sortType ?? "number";
        if (currentSort === sortKey) {
          ascending = !ascending;
        } else {
          currentSort = sortKey;
          // String columns default to ascending (A→Z); numeric default to descending (high→low).
          ascending = sortType === "string";
        }

        for (const th of allTh) {
          th.setAttribute("aria-sort", "none");
          const ind = th.querySelector(".sort-indicator");
          if (ind) ind.textContent = "";
        }
        const activeTh = btn.closest("th");
        activeTh?.setAttribute(
          "aria-sort",
          ascending ? "ascending" : "descending",
        );
        const indicator = btn.querySelector(".sort-indicator");
        if (indicator) indicator.textContent = ascending ? " \u25B2" : " \u25BC";

        const allRows = [...tbody.querySelectorAll("tr")];
        const pairs: [HTMLTableRowElement, HTMLTableRowElement][] = [];
        for (let i = 0; i < allRows.length; i += 2) {
          pairs.push([allRows[i] as HTMLTableRowElement, allRows[i + 1] as HTMLTableRowElement]);
        }

        pairs.sort((a, b) => {
          const aData = JSON.parse(a[0].dataset.entry ?? "{}");
          const bData = JSON.parse(b[0].dataset.entry ?? "{}");
          if (sortType === "string") {
            const aStr = String(aData[sortKey] ?? "");
            const bStr = String(bData[sortKey] ?? "");
            const cmp = aStr.localeCompare(bStr, undefined, { sensitivity: "base", numeric: true });
            return ascending ? cmp : -cmp;
          }
          let aVal: number | null | undefined;
          let bVal: number | null | undefined;
          if (sortKey === "ci") {
            aVal = aData.ci_upper - aData.ci_lower;
            bVal = bData.ci_upper - bData.ci_lower;
          } else {
            aVal = aData[sortKey];
            bVal = bData[sortKey];
          }
          // Null-last: rows with missing values always sink to the bottom
          // regardless of asc/desc direction. cost_per_100q is a common example
          // (rows without token_usage carry null).
          const aMissing = aVal == null || Number.isNaN(aVal);
          const bMissing = bVal == null || Number.isNaN(bVal);
          if (aMissing && bMissing) return 0;
          if (aMissing) return 1;
          if (bMissing) return -1;
          return ascending
            ? (aVal as number) - (bVal as number)
            : (bVal as number) - (aVal as number);
        });

        for (const [entryRow, detailRow] of pairs) {
          tbody.appendChild(entryRow);
          tbody.appendChild(detailRow);
        }

        const colLabel = btn.textContent?.trim().replace(/\s*[\u25B2\u25BC]\s*$/, "") ?? sortKey;
        announce(`Sorted by ${colLabel} ${ascending ? "ascending" : "descending"}.`);
      });
    }
  }

  // Dataset filter: show/hide rows based on active tab
  function filterByDataset(dataset: string) {
    const rows = document.querySelectorAll<HTMLElement>("#leaderboard-table tbody tr[data-dataset]");
    for (const row of rows) {
      const match = dataset === "all" || row.dataset.dataset === dataset;
      row.classList.toggle("hidden", !match);
      if (row.classList.contains("detail-row") && !match) {
        row.classList.add("hidden");
      }
    }

    const cards = document.querySelectorAll<HTMLElement>(".leaderboard-card[data-dataset]");
    for (const card of cards) {
      const match = dataset === "all" || card.dataset.dataset === dataset;
      card.classList.toggle("hidden", !match);
    }
  }

  // View toggle: show/hide variant rows
  function filterByView(view: string) {
    if (view === "all") {
      const rows = document.querySelectorAll<HTMLElement>("[data-variant]");
      for (const row of rows) {
        row.classList.remove("view-hidden");
      }
    } else {
      const rows = document.querySelectorAll<HTMLElement>("[data-variant='variant']");
      for (const row of rows) {
        row.classList.add("view-hidden");
      }
      const bestRows = document.querySelectorAll<HTMLElement>("[data-variant='best']");
      for (const row of bestRows) {
        row.classList.remove("view-hidden");
      }
    }
  }

  document.addEventListener("dataset-filter", ((e: CustomEvent) => {
    filterByDataset(e.detail.dataset);
  }) as EventListener);

  document.addEventListener("view-toggle", ((e: CustomEvent) => {
    filterByView(e.detail.view);
  }) as EventListener);

  initLeaderboard();
</script>

<style>
  .view-hidden {
    display: none !important;
  }
</style>
