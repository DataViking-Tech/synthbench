---

<div class="flex items-center gap-3 justify-center text-sm" id="view-toggle">
  <span class="text-muted">View:</span>
  <button
    class="toggle-btn px-3 py-1.5 rounded-md font-medium transition-colors bg-primary text-white"
    data-view="best"
    aria-pressed="true"
  >
    Best per model
  </button>
  <button
    class="toggle-btn px-3 py-1.5 rounded-md font-medium transition-colors bg-muted/10 text-muted hover:bg-muted/20"
    data-view="all"
    aria-pressed="false"
  >
    All variants
  </button>
</div>

<script>
  function initViewToggle() {
    const container = document.getElementById("view-toggle");
    if (!container) return;

    const buttons = container.querySelectorAll<HTMLButtonElement>(".toggle-btn");

    for (const btn of buttons) {
      btn.addEventListener("click", () => {
        const view = btn.dataset.view ?? "best";

        for (const b of buttons) {
          const isActive = b === btn;
          b.setAttribute("aria-pressed", String(isActive));
          b.classList.toggle("bg-primary", isActive);
          b.classList.toggle("text-white", isActive);
          b.classList.toggle("bg-muted/10", !isActive);
          b.classList.toggle("text-muted", !isActive);
          b.classList.toggle("hover:bg-muted/20", !isActive);
        }

        document.dispatchEvent(
          new CustomEvent("view-toggle", { detail: { view } }),
        );
      });
    }
  }

  initViewToggle();
</script>
