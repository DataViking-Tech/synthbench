---
import Footer from "@/components/shared/Footer.astro";
import Nav from "@/components/shared/Nav.astro";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "SynthBench: Open benchmark for synthetic survey respondent quality",
  noindex = false,
} = Astro.props;

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
  </head>
  <body
    class="min-h-screen bg-surface text-text dark:bg-surface-dark dark:text-text-dark"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white focus:shadow-lg"
      >Skip to main content</a
    >
    <Nav />

    <main id="main-content" tabindex="-1" class="px-4 pb-16 focus:outline-none">
      <slot />
    </main>

    <Footer />
  </body>
</html>
