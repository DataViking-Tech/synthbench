---
import DatasetTabs from "@/components/leaderboard/DatasetTabs.astro";
import DotPlot from "@/components/leaderboard/DotPlot.astro";
import LeaderboardTable from "@/components/leaderboard/LeaderboardTable.astro";
import MetricRadar from "@/components/leaderboard/MetricRadar.astro";
import PerMetricDot from "@/components/leaderboard/PerMetricDot.astro";
import ViewToggle from "@/components/leaderboard/ViewToggle.astro";
import WhiskerPlot from "@/components/leaderboard/WhiskerPlot.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

import leaderboardRaw from "@/data/leaderboard.json";
import type { LeaderboardData } from "@/types/leaderboard";

const leaderboard = leaderboardRaw as LeaderboardData;
const datasets = leaderboard.datasets;
---

<BaseLayout title="Leaderboard - SynthBench">
  <div class="py-12 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Leaderboard</h1>
    <p class="mt-3 text-lg text-muted max-w-2xl mx-auto">
      Full rankings across all datasets and models.
    </p>
  </div>

  <div class="w-full max-w-5xl mx-auto px-4 space-y-4">
    <DatasetTabs datasets={datasets} />
    <ViewToggle />
  </div>

  <LeaderboardTable />
  <MetricRadar />

  <div class="mt-12 space-y-8">
    <DotPlot />
    <PerMetricDot />
    <WhiskerPlot />
  </div>
</BaseLayout>
