---
import BaseLayout from "@/layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const setupHref = `${base}account/setup/`;
---

<BaseLayout title="Account · SynthBench" noindex={true}>
  <div class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-3xl font-semibold tracking-tight text-text dark:text-text-dark">
      Account
    </h1>

    <!-- Signed-out view -->
    <section data-account-state="signed-out" class="mt-8">
      <p class="text-sm text-text dark:text-text-dark">
        Sign in to access gated datasets, view your access history, and manage
        your research profile.
      </p>
      <p
        data-account-not-configured
        class="mt-4 hidden rounded-md border border-yellow-300/50 bg-yellow-100/40 p-4 text-sm text-text dark:text-text-dark"
      >
        Authentication is not configured for this deployment. The buttons below
        are for preview only.
      </p>
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <button
          type="button"
          data-account-signin="github"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-muted/30 bg-surface px-4 py-2.5 text-sm font-semibold text-text shadow-sm hover:bg-muted/10 dark:bg-surface-dark dark:text-text-dark dark:hover:bg-muted/10"
        >
          <svg class="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
          Sign in with GitHub
        </button>
        <button
          type="button"
          data-account-signin="google"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-muted/30 bg-surface px-4 py-2.5 text-sm font-semibold text-text shadow-sm hover:bg-muted/10 dark:bg-surface-dark dark:text-text-dark dark:hover:bg-muted/10"
        >
          <svg class="size-5" viewBox="0 0 48 48" aria-hidden="true">
            <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" />
            <path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" />
            <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" />
            <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" />
          </svg>
          Sign in with Google
        </button>
      </div>
      <p data-account-error class="mt-4 hidden text-sm text-red-600"></p>
    </section>

    <!-- Signed-in view -->
    <section data-account-state="signed-in" class="mt-8 hidden">
      <dl class="grid grid-cols-1 gap-4 rounded-lg border border-muted/20 bg-surface p-6 dark:bg-surface-dark sm:grid-cols-2">
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-muted">Email</dt>
          <dd class="mt-1 text-sm text-text dark:text-text-dark" data-account-email>—</dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-muted">Provider</dt>
          <dd class="mt-1 text-sm text-text dark:text-text-dark" data-account-provider>—</dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-muted">Affiliation</dt>
          <dd class="mt-1 text-sm text-text dark:text-text-dark" data-account-affiliation>—</dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-muted">Research purpose</dt>
          <dd class="mt-1 text-sm text-text dark:text-text-dark" data-account-purpose>—</dd>
        </div>
      </dl>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a
          href={setupHref}
          class="inline-flex items-center rounded-md border border-muted/30 px-3 py-2 text-sm font-semibold text-text dark:text-text-dark hover:bg-muted/10"
        >
          Edit profile
        </a>
        <button
          type="button"
          data-account-signout
          class="inline-flex items-center rounded-md bg-primary px-3 py-2 text-sm font-semibold text-white hover:bg-primary/90"
        >
          Sign out
        </button>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  import {
    type AuthProvider,
    getProfile,
    getSession,
    getSupabaseClient,
    isAuthConfigured,
    safeNextPath,
    signInWithProvider,
    signOut,
    withBase,
  } from "@/lib/auth";

  type StateName = "signed-out" | "signed-in";

  function show(state: StateName): void {
    for (const el of document.querySelectorAll<HTMLElement>("[data-account-state]")) {
      el.classList.toggle("hidden", el.dataset.accountState !== state);
    }
  }

  function setText(selector: string, value: string | null | undefined): void {
    const el = document.querySelector<HTMLElement>(selector);
    if (el) el.textContent = value && value.trim().length > 0 ? value : "—";
  }

  function showError(msg: string): void {
    const el = document.querySelector<HTMLElement>("[data-account-error]");
    if (!el) return;
    el.textContent = msg;
    el.classList.remove("hidden");
  }

  async function renderSignedIn(session: Awaited<ReturnType<typeof getSession>>): Promise<void> {
    if (!session) return;
    show("signed-in");
    setText("[data-account-email]", session.user.email);
    setText("[data-account-provider]", session.user.app_metadata?.provider ?? "unknown");
    const profile = await getProfile(session.user.id);
    setText("[data-account-affiliation]", profile?.affiliation ?? null);
    setText("[data-account-purpose]", profile?.research_purpose ?? null);
  }

  async function bootstrap(): Promise<void> {
    // Signed-out UI is always rendered (even in a preview build without env
    // vars) so the page is testable and the structure is stable. When auth
    // isn't configured we just flag it and short-circuit the click handler.
    const configured = isAuthConfigured();
    if (!configured) {
      document
        .querySelector<HTMLElement>("[data-account-not-configured]")
        ?.classList.remove("hidden");
    }

    const params = new URLSearchParams(window.location.search);

    document.querySelectorAll<HTMLButtonElement>("[data-account-signin]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        if (!configured) {
          showError("Authentication is not configured for this deployment.");
          return;
        }
        const provider = btn.dataset.accountSignin as AuthProvider;
        // Capture caller-supplied "next" so callback can resume after profile setup.
        const next = safeNextPath(params.get("next"));
        const callbackPath = `auth/callback/?next=${encodeURIComponent(next)}`;
        btn.disabled = true;
        const { error } = await signInWithProvider(provider, callbackPath);
        if (error) {
          btn.disabled = false;
          showError(`Sign-in failed: ${error.message}`);
        }
      });
    });

    document.querySelector<HTMLButtonElement>("[data-account-signout]")?.addEventListener("click", async () => {
      await signOut();
      window.location.replace(withBase("account/"));
    });

    if (!configured) {
      show("signed-out");
      return;
    }

    const session = await getSession();
    if (session) {
      await renderSignedIn(session);
    } else {
      show("signed-out");
    }

    getSupabaseClient().auth.onAuthStateChange(async (_event, newSession) => {
      if (newSession) {
        await renderSignedIn(newSession);
      } else {
        show("signed-out");
      }
    });
  }

  bootstrap().catch((err) => {
    console.error("[account] bootstrap failed", err);
    showError("Failed to load account. Please refresh.");
  });
</script>
