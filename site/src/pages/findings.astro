---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LeverHierarchy from "@/components/findings/LeverHierarchy.astro";
import EnsembleGain from "@/components/findings/EnsembleGain.astro";
import TemperatureCurve from "@/components/findings/TemperatureCurve.astro";
import ConditioningGap from "@/components/findings/ConditioningGap.astro";
import TopicGroupedBar from "@/components/findings/TopicGroupedBar.astro";
import ConvergenceLine from "@/components/findings/ConvergenceLine.astro";
---

<BaseLayout title="Findings - SynthBench">
  <div class="py-12 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Research Findings</h1>
    <p class="mt-3 text-lg text-muted max-w-2xl mx-auto">
      Six experiments that reveal what drives synthetic survey quality —
      from the levers that matter most to the biases hiding in default model behavior.
    </p>
  </div>

  <LeverHierarchy />

  <EnsembleGain />

  <TemperatureCurve />

  <ConditioningGap />

  <TopicGroupedBar />

  <ConvergenceLine />
</BaseLayout>
