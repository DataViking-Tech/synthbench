---
import BaseLayout from "@/layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
---

<BaseLayout title="Not found — SynthBench" noindex>
  <section class="mx-auto flex max-w-2xl flex-col items-center py-24 text-center">
    <p class="text-6xl font-bold text-primary">404</p>
    <h1 class="mt-4 text-2xl font-semibold">Page not found</h1>
    <p class="mt-3 text-muted">
      The page you requested doesn't exist — it may have moved, or the link
      might be incorrect.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href={base}
        class="rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary-dark"
        >Home</a
      >
      <a
        href={`${base}leaderboard/`}
        class="rounded-md border border-muted/30 px-4 py-2 text-sm font-semibold hover:border-primary/40 hover:text-primary"
        >Leaderboard</a
      >
      <a
        href={`${base}methodology/`}
        class="rounded-md border border-muted/30 px-4 py-2 text-sm font-semibold hover:border-primary/40 hover:text-primary"
        >Methodology</a
      >
    </div>
  </section>
</BaseLayout>
