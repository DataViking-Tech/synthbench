---
import BaselineDefinitions from "@/components/methodology/BaselineDefinitions.astro";
import CostMethodology from "@/components/methodology/CostMethodology.astro";
import DatasetCards from "@/components/methodology/DatasetCards.astro";
import DatasetPolicyTable from "@/components/methodology/DatasetPolicyTable.astro";
import MetricExplainer from "@/components/methodology/MetricExplainer.astro";
import PhaseRoadmap from "@/components/methodology/PhaseRoadmap.astro";
import PrivateHoldoutSection from "@/components/methodology/PrivateHoldoutSection.astro";
import ProblemFraming from "@/components/methodology/ProblemFraming.astro";
import RelatedWork from "@/components/methodology/RelatedWork.astro";
import ScoringProtocol from "@/components/methodology/ScoringProtocol.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const bibtex = `@software{synthbench2026,
  title   = {SynthBench: Open Benchmark for Synthetic Survey Respondents},
  author  = {DataViking-Tech},
  year    = {2026},
  url     = {https://github.com/DataViking-Tech/synthbench},
  version = {0.1.0}
}`;
---

<BaseLayout title="Methodology - SynthBench">
  <div class="py-12 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Methodology</h1>
    <p class="mt-3 text-lg text-muted max-w-2xl mx-auto">
      How SynthBench measures synthetic survey respondent quality — from the
      metrics we use to the datasets we validate against.
    </p>
  </div>

  <ProblemFraming />

  <MetricExplainer />

  <BaselineDefinitions />

  <DatasetCards />

  <DatasetPolicyTable />

  <PrivateHoldoutSection />

  <ScoringProtocol />

  <CostMethodology />

  <RelatedWork />

  <PhaseRoadmap />

  <!-- Citation -->
  <section class="w-full max-w-4xl mx-auto py-12" id="citation">
    <h2
      class="text-2xl font-bold tracking-tight text-text dark:text-text-dark mb-2"
    >
      Citation
    </h2>
    <p class="text-muted mb-6">
      If you use SynthBench in your research, please cite:
    </p>
    <div class="relative">
      <pre
        class="rounded-lg border border-muted/20 bg-surface p-6 text-sm/6 font-mono text-text overflow-x-auto dark:bg-surface-dark dark:text-text-dark"
        >{bibtex}</pre>
      <button
        type="button"
        class="absolute top-3 right-3 rounded-md p-2 text-muted hover:text-text dark:hover:text-text-dark"
        id="copy-bibtex"
        aria-label="Copy BibTeX"
        data-bibtex={bibtex}
      >
        <svg
          class="size-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"
          ></path>
        </svg>
      </button>
    </div>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById("copy-bibtex");
  if (btn) {
    btn.addEventListener("click", () => {
      const text = btn.dataset.bibtex ?? "";
      navigator.clipboard.writeText(text).then(() => {
        btn.setAttribute("aria-label", "Copied!");
        setTimeout(() => btn.setAttribute("aria-label", "Copy BibTeX"), 2000);
      });
    });
  }
</script>
