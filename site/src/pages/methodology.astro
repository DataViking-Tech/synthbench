---
import AboutSection from "@/components/methodology/AboutSection.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Methodology - SynthBench">
  <div class="py-12 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Methodology</h1>
    <p class="mt-3 text-lg text-muted max-w-2xl mx-auto">
      How SynthBench measures synthetic survey respondent quality.
    </p>
  </div>

  <AboutSection />

  <!-- Placeholder: Expanded metric explainers (Slice 5) -->
  <section class="w-full max-w-4xl mx-auto py-8">
    <h2 class="text-2xl font-bold text-center mb-4">Metric Deep Dive</h2>
    <div class="text-center text-muted py-8 border border-muted/20 rounded-lg">
      Detailed metric explanations with interactive examples coming in a future update.
    </div>
  </section>
</BaseLayout>
