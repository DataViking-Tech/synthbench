---
import BaseLayout from "@/layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const accountHref = `${base}account/`;
const submissionsHref = `${base}account/submissions/`;
const methodologyHref = `${base}methodology/`;
const submitDocsHref = `${base}submit/`;
---

<BaseLayout title="Upload a run · SynthBench" noindex={true}>
  <div class="mx-auto max-w-2xl px-4 py-12">
    <header>
      <h1 class="text-3xl font-semibold tracking-tight text-text dark:text-text-dark">
        Upload a run
      </h1>
      <p class="mt-2 text-sm text-muted">
        Drop in a result JSON you generated with <code>synthbench run</code>. We run the same
        Tier 1–3 checks as the GitHub PR flow — see the
        <a class="underline hover:text-text dark:hover:text-text-dark" href={methodologyHref}>methodology</a>
        or the <a class="underline hover:text-text dark:hover:text-text-dark" href={submitDocsHref}>submission guide</a>
        for what we look for.
      </p>
    </header>

    <!-- Signed-out view -->
    <section data-upload-state="signed-out" class="mt-8 hidden">
      <div class="rounded-md border border-yellow-300/50 bg-yellow-100/40 p-4 text-sm text-text dark:text-text-dark">
        <p class="font-semibold">Sign in to upload a run.</p>
        <p class="mt-1 text-muted">
          Submissions are tied to your account so you can track validation status
          and see the final leaderboard entry.
        </p>
        <div class="mt-3">
          <a
            href={accountHref}
            data-signin-href
            class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary/90"
          >
            Sign in
          </a>
        </div>
      </div>
    </section>

    <!-- Auth not configured / endpoint not configured view -->
    <section data-upload-state="unavailable" class="mt-8 hidden">
      <div class="rounded-md border border-red-300/50 bg-red-100/40 p-4 text-sm text-text dark:text-text-dark">
        <p class="font-semibold">Uploads are not available in this deployment.</p>
        <p class="mt-1 text-muted" data-upload-unavailable-reason></p>
        <p class="mt-2 text-muted">
          You can still submit via the
          <a class="underline" href="https://github.com/DataViking-Tech/synthbench" target="_blank" rel="noopener noreferrer">GitHub PR workflow</a>.
        </p>
      </div>
    </section>

    <!-- Signed-in upload form -->
    <section data-upload-state="signed-in" class="mt-8 hidden">
      <form data-upload-form class="space-y-5">
        <div>
          <label
            for="submission-file"
            class="block text-sm font-medium text-text dark:text-text-dark"
          >
            Result JSON
          </label>
          <input
            id="submission-file"
            name="submission"
            type="file"
            accept="application/json,.json"
            required
            class="mt-1 block w-full cursor-pointer rounded-md border border-muted/30 bg-surface px-3 py-2 text-sm text-text file:mr-3 file:rounded file:border-0 file:bg-primary file:px-3 file:py-1.5 file:text-sm file:font-semibold file:text-white hover:file:bg-primary/90 dark:bg-surface-dark dark:text-text-dark"
          />
          <p class="mt-1 text-xs text-muted">
            Single JSON file, up to 2 MB. Generated by
            <code>synthbench run -o results/</code>.
          </p>
        </div>

        <div data-upload-preview class="hidden rounded-md border border-muted/30 bg-surface/50 p-4 text-sm dark:bg-surface-dark/50">
          <p class="font-semibold text-text dark:text-text-dark">Preview</p>
          <dl class="mt-2 grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
            <dt class="text-muted">Model</dt>
            <dd class="text-text dark:text-text-dark" data-preview-model>—</dd>
            <dt class="text-muted">Dataset</dt>
            <dd class="text-text dark:text-text-dark" data-preview-dataset>—</dd>
            <dt class="text-muted">Framework</dt>
            <dd class="text-text dark:text-text-dark" data-preview-framework>—</dd>
            <dt class="text-muted">Questions</dt>
            <dd class="text-text dark:text-text-dark" data-preview-nq>—</dd>
          </dl>
        </div>

        <p data-upload-error class="hidden text-sm text-red-600"></p>

        <div class="flex items-center justify-between gap-3">
          <a
            href={submissionsHref}
            class="text-sm font-medium text-muted hover:text-text dark:hover:text-text-dark"
          >
            View my submissions
          </a>
          <button
            type="submit"
            class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary/90 disabled:opacity-50"
            data-upload-submit
            disabled
          >
            Upload and validate
          </button>
        </div>
      </form>

      <section
        data-upload-success
        class="mt-6 hidden rounded-md border border-green-400/50 bg-green-100/40 p-4 text-sm"
      >
        <p class="font-semibold text-text dark:text-text-dark">Submission queued.</p>
        <p class="mt-1 text-muted">
          Full validation is running now. Track progress on the
          <a class="underline" href={submissionsHref}>submissions page</a>.
          Successful runs land on the leaderboard within ~5 minutes.
        </p>
        <p class="mt-2 text-xs text-muted" data-upload-success-id></p>
      </section>
    </section>
  </div>
</BaseLayout>

<script>
  import { getUser, isAuthConfigured, withBase } from "@/lib/auth";
  import { previewSubmission, uploadSubmission } from "@/lib/submissions";

  function $(sel: string): HTMLElement | null {
    return document.querySelector<HTMLElement>(sel);
  }

  function showState(state: "signed-in" | "signed-out" | "unavailable"): void {
    for (const s of ["signed-in", "signed-out", "unavailable"] as const) {
      $(`[data-upload-state="${s}"]`)?.classList.toggle("hidden", s !== state);
    }
  }

  function showUnavailable(reason: string): void {
    const el = $("[data-upload-unavailable-reason]");
    if (el) el.textContent = reason;
    showState("unavailable");
  }

  function showError(msg: string): void {
    const el = $("[data-upload-error]");
    if (!el) return;
    el.textContent = msg;
    el.classList.remove("hidden");
  }

  function clearError(): void {
    const el = $("[data-upload-error]");
    if (!el) return;
    el.textContent = "";
    el.classList.add("hidden");
  }

  function showPreview(meta: {
    modelName: string | null;
    dataset: string | null;
    framework: string | null;
    nQuestions: number | null;
  }): void {
    const wrap = $("[data-upload-preview]");
    if (!wrap) return;
    wrap.classList.remove("hidden");
    const set = (sel: string, value: string) => {
      const el = $(sel);
      if (el) el.textContent = value;
    };
    set("[data-preview-model]", meta.modelName ?? "(missing)");
    set("[data-preview-dataset]", meta.dataset ?? "(missing)");
    set("[data-preview-framework]", meta.framework ?? "(missing)");
    set("[data-preview-nq]", meta.nQuestions?.toString() ?? "(missing)");
  }

  function hidePreview(): void {
    $("[data-upload-preview]")?.classList.add("hidden");
  }

  let parsedBody: unknown = null;

  async function bootstrap(): Promise<void> {
    if (!isAuthConfigured()) {
      showUnavailable(
        "This site build was not configured with Supabase auth credentials.",
      );
      return;
    }
    if (!import.meta.env.PUBLIC_GATED_API_BASE) {
      showUnavailable(
        "This site build was not configured with PUBLIC_GATED_API_BASE.",
      );
      return;
    }

    const user = await getUser();
    if (!user) {
      // Build a ?next= back to this page so sign-in returns the user here.
      const signInHref = $("[data-signin-href]") as HTMLAnchorElement | null;
      if (signInHref) {
        const here = window.location.pathname + window.location.search;
        signInHref.href = `${withBase("account/")}?next=${encodeURIComponent(here)}`;
      }
      showState("signed-out");
      return;
    }
    showState("signed-in");

    const fileInput = document.getElementById("submission-file") as HTMLInputElement | null;
    const submit = $("[data-upload-submit]") as HTMLButtonElement | null;
    const form = $("[data-upload-form]") as HTMLFormElement | null;
    const success = $("[data-upload-success]");
    const successId = $("[data-upload-success-id]");
    if (!fileInput || !submit || !form || !success) return;

    fileInput.addEventListener("change", async () => {
      clearError();
      hidePreview();
      submit.disabled = true;
      parsedBody = null;
      const file = fileInput.files?.[0];
      if (!file) return;
      if (file.size > 2 * 1024 * 1024) {
        showError("File is larger than 2 MB.");
        return;
      }
      let text: string;
      try {
        text = await file.text();
      } catch (err) {
        showError(`Could not read file: ${err instanceof Error ? err.message : String(err)}`);
        return;
      }
      let body: unknown;
      try {
        body = JSON.parse(text);
      } catch (err) {
        showError(`Not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
        return;
      }
      const preview = previewSubmission(body);
      if (!preview.ok) {
        showError(preview.error);
        return;
      }
      parsedBody = body;
      showPreview(preview.meta);
      submit.disabled = false;
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      clearError();
      if (parsedBody === null) {
        showError("Pick a file before submitting.");
        return;
      }
      submit.disabled = true;
      const result = await uploadSubmission(parsedBody);
      if (!result.ok) {
        submit.disabled = false;
        showError(result.message);
        return;
      }
      success.classList.remove("hidden");
      if (successId) {
        successId.textContent = `Submission #${result.submissionId} · status: ${result.status}`;
        if (result.warning) {
          successId.textContent += ` · warning: ${result.warning}`;
        }
      }
      form.querySelector("button[type=submit]")?.setAttribute("disabled", "true");
      fileInput.value = "";
      parsedBody = null;
    });
  }

  bootstrap().catch((err) => {
    console.error("[submit/upload] bootstrap failed", err);
    showError("Unexpected error loading the upload form.");
  });
</script>
