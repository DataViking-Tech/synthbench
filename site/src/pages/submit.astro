---
import FAQ from "@/components/submit/FAQ.astro";
import QuickStart from "@/components/submit/QuickStart.astro";
import SubmissionAdapters from "@/components/submit/SubmissionAdapters.astro";
import SubmissionFlow from "@/components/submit/SubmissionFlow.astro";
import SubmissionRequirements from "@/components/submit/SubmissionRequirements.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const uploadHref = `${base}submit/upload/`;
---

<BaseLayout title="Submit - SynthBench">
  <div class="py-12 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
      Submit Your Model
    </h1>
    <p class="mt-3 text-lg text-muted max-w-2xl mx-auto">
      Benchmark your synthetic survey approach against real human data.
    </p>
  </div>

  <QuickStart />

  <SubmissionFlow />

  <SubmissionRequirements />

  <SubmissionAdapters />

  <FAQ />

  <!-- Final CTA -->
  <section class="w-full max-w-4xl mx-auto py-12 text-center">
    <h2
      class="text-2xl font-bold tracking-tight text-text dark:text-text-dark mb-4"
    >
      Ready to benchmark?
    </h2>
    <p class="text-muted mb-6 max-w-lg mx-auto">
      Run the benchmark locally, then upload the result JSON — or open a PR if you
      prefer the power-user path.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href={uploadHref}
        class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary/90 dark:bg-primary-light dark:text-surface-dark dark:hover:bg-primary-light/90"
      >
        Upload a run
      </a>
      <a
        href="https://github.com/DataViking-Tech/synthbench/fork"
        class="inline-flex items-center gap-2 rounded-lg border border-muted/40 bg-surface px-6 py-3 text-sm font-semibold text-text hover:bg-muted/10 dark:bg-surface-dark dark:text-text-dark dark:hover:bg-muted/10"
        target="_blank"
        rel="noopener noreferrer"
      >
        Fork on GitHub<span class="sr-only"> (opens in a new tab)</span>
        <svg
          class="size-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
          />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
