---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Submit - SynthBench">
  <div class="py-12 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Submit Your Model</h1>
    <p class="mt-3 text-lg text-muted max-w-2xl mx-auto">
      Add your model to the SynthBench leaderboard.
    </p>
  </div>

  <div class="w-full max-w-3xl mx-auto py-8 space-y-12">
    <!-- Install -->
    <section>
      <h2 class="text-2xl font-bold mb-4">1. Install SynthBench</h2>
      <pre class="rounded-lg border border-muted/20 bg-surface p-4 text-sm font-mono overflow-x-auto dark:bg-surface-dark">pip install synthbench</pre>
    </section>

    <!-- Run evaluation -->
    <section>
      <h2 class="text-2xl font-bold mb-4">2. Run Evaluation</h2>
      <p class="text-muted mb-4">
        Run the benchmark against your model using the CLI:
      </p>
      <pre class="rounded-lg border border-muted/20 bg-surface p-4 text-sm font-mono overflow-x-auto dark:bg-surface-dark">{`# Run against all datasets
synthbench eval --model your-model-name --provider your-provider

# Run against a specific dataset
synthbench eval --model your-model-name --dataset opinionsqa

# Specify number of replicates (default: 5)
synthbench eval --model your-model-name --replicates 10`}</pre>
    </section>

    <!-- Submit results -->
    <section>
      <h2 class="text-2xl font-bold mb-4">3. Submit Results</h2>
      <p class="text-muted mb-4">
        Submit your results via a pull request to the SynthBench repository:
      </p>
      <ol class="list-decimal list-inside space-y-3 text-muted">
        <li>Fork the <a href="https://github.com/DataViking-Tech/synthbench" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">SynthBench repository</a></li>
        <li>Add your results JSON to <code class="text-sm bg-muted/10 px-1.5 py-0.5 rounded">results/</code></li>
        <li>Open a pull request with your evaluation results</li>
        <li>The CI pipeline validates your submission automatically</li>
      </ol>
    </section>

    <!-- Requirements -->
    <section>
      <h2 class="text-2xl font-bold mb-4">Requirements</h2>
      <ul class="list-disc list-inside space-y-2 text-muted">
        <li>Python 3.10+</li>
        <li>API access to your model provider</li>
        <li>Minimum 5 replicates per dataset for inclusion</li>
        <li>Results must include all standard metrics (SPS, p_dist, p_rank, p_refuse)</li>
      </ul>
    </section>

    <!-- Help -->
    <section>
      <h2 class="text-2xl font-bold mb-4">Need Help?</h2>
      <p class="text-muted">
        Open an issue on <a href="https://github.com/DataViking-Tech/synthbench/issues" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">GitHub</a> or
        check the <a href="https://github.com/DataViking-Tech/synthbench#readme" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">README</a> for detailed documentation.
      </p>
    </section>
  </div>
</BaseLayout>
